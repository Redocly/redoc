        "format": "integer",
        "maximum": 100000,
        "minimum": 0,
        "type": "number",
      },
      "BlankProblem": {
        "additionalProperties": true,
        "description": "Problem Details JSON Object [[RFC7807](https://tools.ietf.org/html/rfc7807)].",
