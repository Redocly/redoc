          {
            "properties": {
              "accountNumber": {
                "description": "Customer's bank account number.
Detailed information on all ISO 13616-compliant national IBAN formats is available in the [SWIFT IBAN Registry](https://www.swift.com/standards/data-standards/iban).",
                "pattern": "^[0-9]+$",
                "type": "string",
              },
              "accountNumberType": {
                "default": "BBAN",
                "description": "Bank account number type.
A valid value is a Basic Bank Account Number (BBAN) or an International Bank Account Number (IBAN).",
                "enum": [
                  "IBAN",
                  "BBAN",
                ],
                "type": "string",
              },
              "accountType": {
                "description": "Bank account type.",
                "enum": [
                  "checking",
                  "savings",
                  "other",
                ],
                "type": "string",
              },
              "bankName": {
                "description": "Bank name.",
                "type": "string",
              },
              "bic": {
                "description": "Bank Identifier Code (BIC).",
                "type": "string",
              },
              "billingAddress": {
                "$ref": "#/components/schemas/ContactObject",
                "description": "Customer's billing address.",
              },
              "customFields": {
                "$ref": "#/components/schemas/ResourceCustomFields",
              },
              "customerId": {
                "$ref": "#/components/schemas/CustomerId",
              },
              "method": {
                "description": "Payment method of the payment instrument.",
                "enum": [
                  "ach",
                ],
                "type": "string",
              },
              "riskMetadata": {
                "$ref": "#/components/schemas/RiskMetadata",
              },
              "routingNumber": {
                "description": "Bank routing number.",
                "pattern": "^[0-9]+$",
                "type": "string",
              },
              "useAsBackup": {
                "$ref": "#/components/schemas/UseAsBackup",
              },
            },
          },
        ],
        "description": "BBAN type object.",
