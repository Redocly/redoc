      "Dispute": {
        "properties": {
          "_embedded": {
            "description": "Embedded objects that are requested by the \`expand\` query parameter.",
            "properties": {
              "transaction": {
                "type": "object",
              },
            },
            "readOnly": true,
            "type": "object",
          },
          "_links": {
            "description": "Related links.",
            "items": {
              "properties": {
                "href": {
                  "description": "Link URL.",
                  "type": "string",
                },
                "rel": {
                  "description": "Type of link.",
                  "enum": [
                    "self",
                    "transaction",
                    "attachments",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "acquirerReferenceNumber": {
            "description": "Acquirer reference number for the dispute.",
            "type": [
              "string",
              "null",
            ],
          },
          "amount": {
            "description": "Dispute amount.",
            "format": "double",
            "type": "number",
          },
          "caseId": {
            "description": "Case ID of the dispute.",
            "type": [
              "string",
              "null",
            ],
          },
          "category": {
            "description": "Category of dispute.",
            "enum": [
              "fraud",
              "authorization",
              "processing-errors",
              "consumer-disputes",
              "uncategorized",
              "bank-return",
            ],
            "readOnly": true,
            "type": "string",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "currency": {
            "$ref": "#/components/schemas/CurrencyCode",
          },
          "customerId": {
            "description": "ID of the customer who is disputing a transaction.",
            "example": "cus_0YV7DDSDD1C8DA64KHH2W33CPF",
            "maxLength": 50,
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "deadlineTime": {
            "description": "Latest date and time by when a merchant must submit a representment for a dispute.
If the deadline is missed, the merchant loses the dispute.",
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
          },
          "id": {
            "description": "ID of the dispute.",
            "example": "dp_0YVCE8J5F2DE58FV0S8YASW4HK",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "postedTime": {
            "description": "Date and time when the dispute is posted.",
            "format": "date-time",
            "type": "string",
          },
          "rawResponse": {
            "description": "Raw response from the payment gateway that processed the disputed transaction.",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "reasonCode": {
            "description": "Code used in the chargeback that describes the reason for the dispute.",
            "maxLength": 255,
            "type": [
              "string",
              "null",
            ],
          },
          "reasonDescription": {
            "description": "Description of the reason for the dispute.",
            "maxLength": 512,
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "resolvedTime": {
            "description": "Date and time when the dispute is resolved.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "revision": {
            "description": "Number of times the dispute data has been modified.

Use the revision number when analyzing webhook data to
determine if a change should take precedence over the current
representation.",
            "readOnly": true,
            "type": "integer",
          },
          "source": {
            "description": "Source of the dispute.",
            "enum": [
              null,
              "api",
              "manual",
              "sftp",
              "webhook",
            ],
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "status": {
            "description": "Status of the dispute.",
            "enum": [
              "response-needed",
              "under-review",
              "forfeited",
              "won",
              "lost",
              "unknown",
            ],
            "type": "string",
          },
          "transactionId": {
            "description": "ID of the disputed transaction.",
            "example": "txn_0YVDTQJ8YWDGQACV2N2N5SPWQ0",
            "maxLength": 50,
            "type": [
              "string",
              "null",
            ],
          },
          "type": {
            "description": "Type of dispute.",
            "enum": [
              "information-request",
              "first-chargeback",
              "second-chargeback",
              "arbitration",
              "fraud",
              "ethoca-alert",
              "verifi-alert",
              "bank-return",
              "paypal-claim",
            ],
            "type": "string",
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
        },
        "type": "object",
      },
