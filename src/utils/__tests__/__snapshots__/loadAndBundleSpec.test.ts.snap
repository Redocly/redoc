      "SubscriptionPause": {
        "description": "Subscription pause details.",
        "properties": {
          "_links": {
            "$ref": "#/components/schemas/SelfLink",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "description": {
            "description": "Description of the pause reason in free form.",
            "maxLength": 255,
            "type": [
              "string",
              "null",
            ],
          },
          "effectiveTime": {
            "description": "Date and time when the service period pauses.

This time must be later than the current time.
If this time is earlier then the current time, the current time is used.

If this field is omitted, this value defaults to the current time.",
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
          },
          "endTime": {
            "description": "Date and time when the pause ends and the subscription resumes billing.

To resume a subscription from this point in time,
use the current time or an earlier time.
If \`endTime\` is earlier then the current time, the current time is used.
If this field is empty, the subscription is indefinitely paused.",
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
          },
          "id": {
            "description": "ID of the subscription pause.",
            "example": "sub_pau_01H085J3ZR1WKD120D73D7N4C9",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "pausedBy": {
            "default": "customer",
            "description": "Specifies who initiated the pause.",
            "enum": [
              "merchant",
              "customer",
            ],
            "type": "string",
          },
          "status": {
            "description": "Status of the subscription pause.",
            "enum": [
              "pending",
              "ongoing",
              "revoked",
              "finished",
            ],
            "readOnly": true,
            "type": "string",
          },
          "subscriptionId": {
            "description": "ID of the paused subscription.",
            "example": "sub_01HRF27SATGE4Z6PBJE6PD8328",
            "maxLength": 50,
            "type": "string",
          },
          "timeRemaining": {
            "description": "Amount of time between the pause end time and the renewal time in ISO-8601 durations format.
By default, this value is computed as the time between the pause and the renewal.

Example: A $30 per month subscription on a 30-day month is paused on day 20 of the subscription.
There are 10 unused days on the subscription.
Therefore, the subscription renews in 10 days after it is resumed.
The upcoming invoice does not change the amount for the invoiced period, it remains at $30.
If the subscription uses a billing anchor,
the renewal time after a pause shift behaves as though the renewal time is moved forward by an [Order API operation](../../tag/Orders),
and the billing anchor is ignored for that period.

For more information, see [Service period anchor, billing timing, and invoice time shift](https://www.rebilly.com/docs/dev-docs/concepts/#service-period-anchor-and-billing-timing-and-invoice-time-shift).",
            "example": "P3600S",
            "type": [
              "string",
              "null",
            ],
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
        },
        "required": [
          "subscriptionId",
        ],
        "type": "object",
      },
      "SubscriptionPlan": {
        "description": "Details of the subscription order plan. Use this plan for subscriptions or sales that reoccur over a period of time.",
        "properties": {
          "_links": {
            "description": "Related links.",
            "items": {
              "properties": {
                "href": {
                  "description": "Link URL.",
                  "type": "string",
                },
                "rel": {
                  "description": "Type of link.",
                  "enum": [
                    "self",
                    "attachments",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "currency": {
            "$ref": "#/components/schemas/CurrencyCode",
          },
          "currencySign": {
            "description": "Currency sign.",
            "readOnly": true,
            "type": "string",
          },
          "customFields": {
            "$ref": "#/components/schemas/ResourceCustomFields",
          },
          "description": {
            "description": "Plain-text description of the plan.
This field accepts plain-text only.",
            "maxLength": 65535,
            "type": "string",
          },
          "invoiceTimeShift": {
            "$ref": "#/components/schemas/InvoiceTimeShift",
          },
          "isActive": {
            "default": true,
            "description": "Specifies if the plan is active.",
            "type": "boolean",
          },
          "isTrialOnly": {
            "description": "Specifies if a plan is a trial that does not have recurring instructions.",
            "readOnly": true,
            "type": "boolean",
          },
          "meteredBilling": {
            "description": "Use metered billing when an exact quantity is unknown.
Report usage during a service period and charge customers afterwards.
Metered billing plans must be postpaid.",
            "properties": {
              "max": {
                "description": "Maximum quantity that is charged at the end of a service period regardless of reported usage.",
                "format": "float",
                "minimum": 0.01,
                "type": [
                  "number",
                  "null",
                ],
              },
              "min": {
                "description": "Minimum quantity that is charged at the end of a service period regardless of reported usage.",
                "format": "float",
                "minimum": 0.01,
                "type": [
                  "number",
                  "null",
                ],
              },
              "strategy": {
                "enum": [
                  "sum",
                  "last",
                ],
                "type": "string",
                "x-enumDescriptions": {
                  "last": "Last reported invoice item quantity usage.",
                  "sum": "Total amount of reported invoice item quantity usage.",
                },
              },
            },
            "required": [
              "strategy",
            ],
            "type": [
              "object",
              "null",
            ],
          },
          "name": {
            "description": "Name of the plan.
This name is displayed on invoices and receipts.",
            "maxLength": 255,
            "type": "string",
          },
          "pricing": {
            "$ref": "#/components/schemas/PlanPriceFormula",
          },
          "productId": {
            "description": "ID of the related product.",
            "example": "prod_0YV7DES3WPC5J8JD8QTVNZBZNZ",
            "maxLength": 50,
            "type": "string",
          },
          "productOptions": {
            "additionalProperties": {
              "type": "string",
            },
            "description": "Name-value pairs that specify the product options.",
            "example": {
              "color": "red",
              "size": "xxl",
            },
            "type": [
              "object",
              "null",
            ],
          },
          "recurringInterval": {
            "description": "Service interval settings.
For a one-time sale, set this value to \`null\`.",
            "properties": {
              "billingTiming": {
                "default": "prepaid",
                "description": "Billing timing in relation to the service period.
For \`prepaid\` plans the customer pays when the service period starts,
whereas, for \`postpaid\` plans, the customer pays when the service period ends.",
                "enum": [
                  "prepaid",
                  "postpaid",
                ],
                "type": "string",
              },
              "length": {
                "description": "Length of time.",
                "minimum": 1,
                "type": "integer",
              },
              "limit": {
                "description": "Number of invoices the subscription order generates.
If this value is \`1\`, only the initial order creation is generated.

Example: For a 1 year contract that is billed monthly,
where the \`periodUnit\` is \`month\` and the \`periodDuration\` is \`1\`,
set this field to \`12\`.",
                "maximum": 65535,
                "minimum": 1,
                "type": [
                  "integer",
                  "null",
                ],
              },
              "periodAnchorInstruction": {
                "$ref": "#/components/schemas/ServicePeriodAnchorInstruction",
              },
              "unit": {
                "description": "Unit of time.",
                "enum": [
                  "day",
                  "week",
                  "month",
                  "year",
                ],
                "type": "string",
              },
            },
            "type": "object",
          },
          "revision": {
            "description": "Number of times the plan is modified.
Compare this value with materialized subscription item revision values.",
            "readOnly": true,
            "type": "integer",
          },
          "richDescription": {
            "description": "Rich-text description of the plan.
This field accepts rich text formatting, such as: bold, underline, italic, and hyperlinks.",
            "maxLength": 65535,
            "type": "string",
          },
          "setup": {
            "$ref": "#/components/schemas/PlanSetup",
          },
          "trial": {
            "description": "Trial configuration setting.
If you do not want to offer a trial, set this value to \`null\`.",
            "oneOf": [
              {
                "$ref": "#/components/schemas/PlanTrial",
              },
              {
                "type": "null",
              },
            ],
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
        },
        "required": [
          "name",
          "currency",
          "productId",
          "pricing",
          "recurringInterval",
        ],
        "type": "object",
      },
      "SubscriptionReactivation": {
        "properties": {
          "_links": {
            "$ref": "#/components/schemas/SelfLink",
          },
          "cancellationId": {
            "description": "ID of the related cancellation.",
            "example": "sub_cnl_0YVJ5XVQM9CDP8248ZQX0RDMKV",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "description": {
            "description": "Description of the reactivation reason in free form.",
            "maxLength": 255,
            "type": [
              "string",
              "null",
            ],
          },
          "effectiveTime": {
            "description": "Date and time when the service period starts,
unless the subscription is canceled but still active.

If the subscription is still active,
the subscription continues for the current service period.

If this field is omitted, this value defaults to the current time.",
            "format": "date-time",
            "type": "string",
            "writeOnly": true,
          },
          "id": {
            "description": "ID of the reactivation.",
            "example": "sub_rct_0YVJ62AF5XCFCA6EBFAAA3Z7E0",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "paymentInstrumentId": {
            "description": "ID of the payment instrument.
If this field is omitted, the subscription payment instrument remains unchanged.",
            "example": "4f6cf35x-2c4y-483z-a0a9-158621f77a21",
            "maxLength": 50,
            "type": [
              "string",
              "null",
            ],
            "writeOnly": true,
          },
          "renewalTime": {
            "description": "Date and time of the next subscription renewal.
If this field is omitted, this value is computed from the \`effectiveTime\` field.

If the subscription is canceled but still active,
it is ignored and the next renewal occurs as scheduled.",
            "format": "date-time",
            "type": "string",
          },
          "subscriptionId": {
            "description": "ID of the reactivated subscription.",
            "example": "sub_01HRF27SATGE4Z6PBJE6PD8328",
            "maxLength": 50,
            "type": "string",
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
        },
        "required": [
          "subscriptionId",
        ],
        "type": "object",
      },
      "Tag": {
        "description": "Use tags to organize and categorize customers or KYC documents based on keywords.
For more information, see [Tags](https://www.rebilly.com/docs/dev-docs/api/tags/).",
        "properties": {
          "_links": {
            "$ref": "#/components/schemas/SelfLink",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "id": {
            "$ref": "#/components/schemas/ResourceId",
            "description": "ID of the tag.",
            "readOnly": true,
          },
          "name": {
            "description": "Unique name for the tag.
Tag names are not case-sensitive.",
            "example": "New",
            "maxLength": 255,
            "pattern": "^[@~\\-\\.\\w\\s]+$",
            "type": "string",
          },
          "type": {
            "description": "Type of tag.
Tags of a specific type can only be assigned to corresponding entity types.
For example, you can only use customer tags on customers.",
            "enum": [
              "customer",
              "kyc-document",
              "aml-check",
            ],
            "type": "string",
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
        },
        "required": [
          "name",
          "type",
        ],
        "type": "object",
      },
      "TagUntagRule": {
        "description": "Tag or untag rule.",
        "properties": {
          "_links": {
            "description": "Related resource links.",
            "items": {
              "properties": {
                "href": {
                  "description": "Link URL.",
                  "type": "string",
                },
                "rel": {
                  "description": "Type of link.",
                  "enum": [
                    "self",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "addTags": {
            "description": "List of tags to add to the customer.",
            "items": {
              "type": "string",
            },
            "maxItems": 1000,
            "minItems": 0,
            "type": "array",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "eventType": {
            "allOf": [
              {
                "$ref": "#/components/schemas/GlobalEventType",
              },
              {
                "not": {
                  "enum": [
                    "application-instance-disabled",
                    "application-instance-enabled",
                    "balance-transaction-settled",
                    "credit-memo-applied",
                    "credit-memo-created",
                    "credit-memo-modified",
                    "credit-memo-partially-applied",
                    "credit-memo-voided",
                    "customer-redirected-offsite",
                    "customer-returned",
                    "dispute-created",
                    "dispute-modified",
                    "gateway-account-downtime-ended",
                    "gateway-account-downtime-started",
                    "gateway-account-limit-reached",
                    "gateway-account-onboarding-completed",
                    "gateway-account-onboarding-failed",
                    "gateway-account-requested",
                    "invoice-created",
                    "invoice-modified",
                    "invoice-past-due-reminder",
                    "invoice-tax-calculation-failed",
                    "nsf-response-received",
                    "offsite-payment-completed",
                    "order-abandon-reminder",
                    "organization-tax-number-validated",
                    "payment-card-created",
                    "payment-card-expiration-reminder",
                    "payment-instrument-modified",
                    "renewal-invoice-payment-canceled",
                    "risk-score-changed",
                    "subscription-items-changed",
                    "subscription-modified",
                    "subscription-pause-created",
                    "subscription-pause-modified",
                    "subscription-pause-revoked",
                    "subscription-renewal-reminder",
                    "subscription-trial-converted",
                    "subscription-trial-end-changed",
                    "subscription-trial-end-reminder",
                    "subscription-trial-ended",
                    "transaction-process-requested",
                    "transaction-reconciled",
                    "transaction-timeout-resolved",
                    "waiting-gateway-transaction-completed",
                    "data-export-completed",
                    "hard-usage-limit-reached",
                    "soft-usage-limit-reached",
                  ],
                },
              },
            ],
          },
          "filter": {
            "description": "Filter that determines whether to tag or untag.
This field requires a special format.
Use \`,\` for multiple allowed values.
Use \`;\` for multiple fields.

For more information,
see [Using filters](https://api-reference.rebilly.com/#section/Using-filter-with-collections).",
            "type": [
              "string",
              "null",
            ],
          },
          "id": {
            "description": "ID of the rule.",
            "example": "tag_rule_0YVCEE5APAD7V84MK3P9CCJVYY",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "name": {
            "description": "Name of the rule.",
            "type": "string",
          },
          "removeTags": {
            "description": "List of tags to remove for the customer.",
            "items": {
              "type": "string",
            },
            "maxItems": 1000,
            "minItems": 0,
            "type": "array",
          },
          "status": {
            "default": "active",
            "description": "Status of the rule.",
            "enum": [
              "active",
              "inactive",
            ],
            "type": "string",
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
        },
        "required": [
          "name",
          "eventType",
          "addTags",
          "removeTags",
        ],
        "type": "object",
      },
      "TaxItem": {
        "properties": {
          "amount": {
            "description": "Amount of the tax.",
            "format": "double",
            "type": "number",
          },
          "cityAmount": {
            "description": "Amount of sales tax to collect for the city.",
            "example": 0,
            "format": "double",
            "readOnly": true,
            "type": [
              "number",
              "null",
            ],
          },
          "cityRate": {
            "description": "City sales tax rate for given location.",
            "format": "double",
            "readOnly": true,
            "type": [
              "number",
              "null",
            ],
          },
          "countyAmount": {
            "description": "Amount of sales tax to collect for the county.",
            "example": 0.04,
            "format": "double",
            "readOnly": true,
            "type": [
              "number",
              "null",
            ],
          },
          "countyRate": {
            "description": "County sales tax rate for given location.",
            "format": "double",
            "readOnly": true,
            "type": [
              "number",
              "null",
            ],
          },
          "description": {
            "description": "Description of the tax.",
            "type": "string",
          },
          "jurisdictions": {
            "description": "Jurisdiction names for the invoice.",
            "properties": {
              "city": {
                "description": "City name for the provided location.",
                "example": "LOS ANGELES",
                "readOnly": true,
                "type": [
                  "string",
                  "null",
                ],
              },
              "country": {
                "description": "Two-letter ISO country code for the provided location.",
                "example": "US",
                "readOnly": true,
                "type": [
                  "string",
                  "null",
                ],
              },
              "county": {
                "description": "County name for the provided location.",
                "example": "LOS ANGELES",
                "readOnly": true,
                "type": [
                  "string",
                  "null",
                ],
              },
              "state": {
                "description": "Postal abbreviated state name for the provided location.",
                "example": "CA",
                "readOnly": true,
                "type": [
                  "string",
                  "null",
                ],
              },
            },
            "readOnly": true,
            "type": [
              "object",
              "null",
            ],
          },
          "rate": {
            "description": "Overall sales tax rate which includes state, county, city and district tax.",
            "format": "double",
            "readOnly": true,
            "type": [
              "number",
              "null",
            ],
          },
          "specialDistrictAmount": {
            "description": "Amount of sales tax to collect for the special district.",
            "example": 0.38,
            "format": "double",
            "readOnly": true,
            "type": [
              "number",
              "null",
            ],
          },
          "specialDistrictRate": {
            "description": "Special district sales tax rate for given location.",
            "format": "double",
            "readOnly": true,
            "type": [
              "number",
              "null",
            ],
          },
          "stateAmount": {
            "description": "Amount of sales tax to collect for the state.",
            "example": 0.94,
            "format": "double",
            "readOnly": true,
            "type": [
              "number",
              "null",
            ],
          },
          "stateRate": {
            "description": "State sales tax rate for given location.",
            "format": "double",
            "readOnly": true,
            "type": [
              "number",
              "null",
            ],
          },
        },
        "required": [
          "amount",
          "description",
        ],
        "type": "object",
      },
      "TaxNumber": {
        "properties": {
          "isDefault": {
            "description": "Determines if the tax number is selected as default to display on invoices.",
            "example": true,
            "type": "boolean",
          },
          "isValid": {
            "description": "Determines if the tax number passed the EU official [VIES validation](https://ec.europa.eu/taxation_customs/vies/#/vat-validation).",
            "example": true,
            "readOnly": true,
            "type": [
              "boolean",
              "null",
            ],
          },
          "type": {
            "description": "Type of the tax number.",
            "enum": [
              "eu-vat",
              "other",
            ],
            "example": "eu-vat",
            "type": "string",
          },
          "value": {
            "description": "Value of the tax number.",
            "example": "GB980780684",
            "type": "string",
          },
        },
        "required": [
          "type",
          "value",
        ],
        "type": "object",
      },
      "Taxes": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/ManualTax",
          },
          {
            "$ref": "#/components/schemas/RebillyTaxJarTax",
          },
          {
            "$ref": "#/components/schemas/RebillyAvalaraTax",
          },
        ],
        "description": "Taxes.",
        "discriminator": {
          "mapping": {
            "manual": "#/components/schemas/ManualTax",
            "rebilly-avalara": "#/components/schemas/RebillyAvalaraTax",
            "rebilly-taxjar": "#/components/schemas/RebillyTaxJarTax",
          },
          "propertyName": "calculator",
        },
        "type": "object",
      },
      "ThreeColumnsTimelineTable": {
        "allOf": [
          {
            "$ref": "#/components/schemas/TimelineTable",
          },
          {
            "properties": {
              "data": {
                "description": "Table data. Each array element represents a table row.",
                "items": {
                  "example": {
                    "attribute": "Descriptor",
                    "newValue": "new-test.com",
                    "previousValue": "test.com",
                  },
                  "properties": {
                    "attribute": {
                      "type": "string",
                    },
                    "newValue": {
                      "type": "string",
                    },
                    "previousValue": {
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
                "type": "array",
              },
            },
            "type": "object",
          },
        ],
      },
      "TimeIso8601Extended": {
        "description": "Extended ISO-8601 format of time.",
        "format": "time",
        "pattern": "^(([01][0-9]|2[0-3]):([0-5][0-9])(?::([0-5][0-9]))?)((?:[+-](?:0[0-9]|1[12])(?::?[0-5][0-9])?)|Z)?$",
        "type": "string",
      },
      "TimePluralUnit": {
        "enum": [
          "seconds",
          "minutes",
          "hours",
          "days",
          "months",
          "years",
        ],
        "type": "string",
      },
      "TimeUnit": {
        "enum": [
          "second",
          "minute",
          "hour",
          "day",
          "month",
          "year",
        ],
        "type": "string",
      },
      "TimelineAction": {
        "discriminator": {
          "mapping": {
            "redemption-cancel": "#/components/schemas/RedemptionCancelTimelineAction",
            "resend-email": "#/components/schemas/ResendEmailTimelineAction",
            "ruleset-restore": "#/components/schemas/RulesetRestoreTimelineAction",
            "show-edd-search-logs": "#/components/schemas/ShowEddSearchLogsTimelineAction",
          },
          "propertyName": "action",
        },
        "oneOf": [
          {
            "$ref": "#/components/schemas/RedemptionCancelTimelineAction",
          },
          {
            "$ref": "#/components/schemas/ResendEmailTimelineAction",
          },
          {
            "$ref": "#/components/schemas/RulesetRestoreTimelineAction",
          },
          {
            "$ref": "#/components/schemas/ShowEddSearchLogsTimelineAction",
          },
        ],
        "type": "object",
      },
      "TimelineExtraData": {
        "description": "Additional data.",
        "properties": {
          "actions": {
            "description": "Actions available for a timeline message.
If no actions are available, this field is empty.",
            "items": {
              "$ref": "#/components/schemas/TimelineAction",
            },
            "minItems": 0,
            "type": "array",
          },
          "author": {
            "description": "Author of the timeline message.",
            "properties": {
              "userFullName": {
                "description": "Author's full name.",
                "type": "string",
              },
              "userId": {
                "description": "Author's user ID.",
                "example": "usr_0YVCEENYJ3D7Q9EN6BN16HA0G4",
                "maxLength": 50,
                "type": "string",
              },
            },
            "type": "object",
          },
          "links": {
            "description": "Links that are attached to a timeline message.",
            "items": {
              "properties": {
                "externalUrl": {
                  "example": "http://example.com",
                  "type": "string",
                },
                "placeholder": {
                  "example": "KYC document",
                  "type": "string",
                },
                "resourceId": {
                  "$ref": "#/components/schemas/ResourceId",
                },
                "resourceType": {
                  "enum": [
                    "kyc-document",
                    "invoice",
                    "subscription",
                    "transaction",
                    "email-message",
                    "dispute",
                    "coupon",
                    "external",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "type": "array",
          },
          "mentions": {
            "additionalProperties": {
              "type": "string",
            },
            "description": "User mentions, or tags, in a timeline.",
            "example": {
              "@test@mail.com": "userId-1",
            },
            "type": "object",
          },
          "tables": {
            "description": "Table data that is attached to the timeline message.",
            "items": {
              "$ref": "#/components/schemas/TimelineTable",
            },
            "minItems": 0,
            "type": "array",
          },
        },
        "readOnly": true,
        "type": "object",
      },
      "TimelineTable": {
        "description": "Additional timeline message information.",
        "discriminator": {
          "mapping": {
            "list": "#/components/schemas/ListTimelineTable",
            "one-column": "#/components/schemas/OneColumnTimelineTable",
            "three-columns": "#/components/schemas/ThreeColumnsTimelineTable",
            "two-columns": "#/components/schemas/TwoColumnsTimelineTable",
          },
          "propertyName": "type",
        },
        "properties": {
          "footer": {
            "description": "Data table footer.",
            "type": "string",
          },
          "title": {
            "description": "Data table title.",
            "type": "string",
          },
          "type": {
            "enum": [
              "list",
              "one-columns",
              "two-columns",
              "three-columns",
            ],
            "type": "string",
          },
        },
        "type": "object",
      },
      "Transaction": {
        "description": "Transaction information.",
        "properties": {
          "3ds": {
            "description": "Authentication object.",
            "properties": {
              "authenticated": {
                "description": "Authentication response status for 3D Secure.",
                "enum": [
                  "yes",
                  "no",
                  "not applicable",
                  "attempted",
                ],
                "type": "string",
              },
              "enrolled": {
                "description": "Specifies if the cardholder is enrolled in 3D Secure.",
                "enum": [
                  "yes",
                  "no",
                  "invalid card/timeout",
                  "unavailable",
                ],
                "type": "string",
              },
              "flow": {
                "description": "Authentication flow for 3D Secure 2.",
                "enum": [
                  "frictionless",
                  "challenge",
                ],
                "type": "string",
              },
              "isDowngraded": {
                "default": false,
                "deprecated": true,
                "description": "Specifies if 3D Secure 2 is attempted and downgraded to 3D Secure 1.",
                "type": "boolean",
              },
              "liability": {
                "enum": [
                  "protected",
                  "not protected",
                  "protected (attempt)",
                ],
                "type": "string",
              },
              "server": {
                "description": "Name of the 3D Secure server.",
                "type": "string",
              },
              "version": {
                "description": "Version of 3D Secure.",
                "enum": [
                  "1.0.2",
                  "2.1.0",
                  "2.2.0",
                ],
                "type": "string",
              },
            },
            "readOnly": true,
            "type": "object",
          },
          "_embedded": {
            "description": "Embedded objects that are requested by the \`expand\` query parameter.",
            "properties": {
              "bankAccount": {
                "type": "object",
              },
              "childTransactions": {
                "description": "Most recent child transactions.",
                "maxItems": 10,
                "type": "array",
              },
              "customer": {
                "type": "object",
              },
              "dispute": {
                "type": "object",
              },
              "gatewayAccount": {
                "type": "object",
              },
              "invoices": {
                "description": "Most recent related invoices.",
                "maxItems": 10,
                "type": "array",
              },
              "leadSource": {
                "type": "object",
              },
              "organization": {
                "type": "object",
              },
              "parentTransaction": {
                "type": "object",
              },
              "paymentCard": {
                "type": "object",
              },
              "website": {
                "type": "object",
              },
            },
            "readOnly": true,
            "type": "object",
          },
          "_links": {
            "description": "Related links.",
            "items": {
              "properties": {
                "href": {
                  "description": "Link URL.",
                  "type": "string",
                },
                "rel": {
                  "description": "Type of link.",
                  "enum": [
                    "self",
                    "attachments",
                    "website",
                    "customer",
                    "gatewayAccount",
                    "paymentCard",
                    "parentTransaction",
                    "leadSource",
                    "approvalUrl",
                    "refundUrl",
                    "updateUrl",
                    "disputes",
                    "invoices",
                    "queryUrl",
                    "redirectUrl",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "acquirerName": {
            "allOf": [
              {
                "$ref": "#/components/schemas/AcquirerName",
              },
            ],
            "description": "Acquirer name.
This value is only available when a transaction uses a payment gateway.
If a transaction does not use a payment gateway, this value is \`null\`.",
            "readOnly": true,
          },
          "amount": {
            "description": "Total amount of the transaction.",
            "format": "double",
            "readOnly": true,
            "type": "number",
            "x-basic": true,
            "x-sortable": true,
            "x-type": "Money",
          },
          "arn": {
            "description": "Acquirer reference number.",
            "example": "74836950144358910018150",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
            "x-label": "ARN",
          },
          "billingAddress": {
            "$ref": "#/components/schemas/ContactObject",
            "description": "Billing address.",
          },
          "billingDescriptor": {
            "description": "Billing descriptor that appears on the periodic billing statement.
For a credit card statement, this field commonly contains 12 or fewer characters.",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "bin": {
            "description": "Payment card Bank Identification Number (BIN).",
            "format": "bin",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
            "x-label": "BIN",
          },
          "bumpOffer": {
            "description": "Bump offer information.
If the transaction does not have an associated bump offer, this value is \`null\`.",
            "properties": {
              "language": {
                "$ref": "#/components/schemas/LanguageIsoCode",
                "description": "Language in which the bump offer displays to the user.
This field in useful to find translation issues.",
              },
              "order": {
                "$ref": "#/components/schemas/Money",
                "description": "Initial amount and currency.",
              },
              "outcome": {
                "description": "Status of the bump offer.",
                "enum": [
                  "presented",
                  "rejected",
                  "selected",
                  "unknown",
                ],
                "readOnly": true,
                "type": "string",
              },
              "presentedOffers": {
                "description": "Offers presented to a customer.",
                "items": {
                  "$ref": "#/components/schemas/PurchaseBumpOffer",
                },
                "minItems": 1,
                "readOnly": true,
                "type": "array",
              },
              "selectedOffer": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/PurchaseBumpOffer",
                  },
                ],
                "description": "Offer selected by a customer.
If a bump offer outcome is not \`selected\`, this value is \`null\`.",
                "readOnly": true,
              },
              "version": {
                "description": "Name of the version selected.
This field is useful to measure split tests.",
                "type": "string",
              },
            },
            "readOnly": true,
            "type": [
              "object",
              "null",
            ],
          },
          "childTransactions": {
            "description": "IDs of child transactions.",
            "items": {
              "$ref": "#/components/schemas/ResourceId",
            },
            "readOnly": true,
            "type": "array",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "currency": {
            "$ref": "#/components/schemas/CurrencyCode",
            "readOnly": true,
          },
          "customFields": {
            "$ref": "#/components/schemas/ResourceCustomFields",
          },
          "customerId": {
            "allOf": [
              {
                "$ref": "#/components/schemas/CustomerId",
              },
            ],
            "x-basic": true,
            "x-sortable": true,
          },
          "dcc": {
            "description": "Detailed Dynamic currency conversion (DCC).
If DCC is not applied to the transaction, this value is \`null\`.",
            "properties": {
              "base": {
                "$ref": "#/components/schemas/Money",
                "description": "Initial amount and currency to convert from.",
              },
              "outcome": {
                "description": "Dynamic currency conversion outcome.",
                "enum": [
                  "rejected",
                  "selected",
                  "unknown",
                ],
                "type": "string",
              },
              "quote": {
                "$ref": "#/components/schemas/Money",
                "description": "Suggested amount and currency to convert to.",
              },
              "usdMarkup": {
                "$ref": "#/components/schemas/MoneyAmount",
                "description": "Markup amount converted to USD.",
              },
            },
            "readOnly": true,
            "type": [
              "object",
              "null",
            ],
          },
          "depositRequestId": {
            "description": "ID of the deposit request if applicable. The created transaction is based on the properties of this deposit request.",
            "example": "dep_req_0YVJ65BSGYC3EAT58SEX8KY6J7",
            "maxLength": 50,
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "description": {
            "description": "Description of the payment.",
            "maxLength": 255,
            "type": "string",
          },
          "discrepancyTime": {
            "description": "Date and time of the most recent discrepancy on the transaction.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
            "x-sortable": true,
          },
          "disputeStatus": {
            "description": "Status of the dispute.",
            "enum": [
              null,
              "response-needed",
              "under-review",
              "forfeited",
              "won",
              "lost",
              "unknown",
            ],
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "disputeTime": {
            "description": "Date and time when the dispute is created.
If the transaction is not disputed, this value is \`null\`.",
