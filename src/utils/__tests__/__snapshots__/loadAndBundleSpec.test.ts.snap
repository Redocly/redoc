            "source": "$customerForm = new Rebilly\\Entities\\Customer();
$customerForm->setPrimaryAddress([
    'firstName' => 'John',
    'lastName' => 'Doe',
    'organization' => 'Test LTD',
    'address' => 'Test street 5',
    'address2' => 'Test house 5',
    'city' => 'New York',
    'region' => 'Long Island',
    'country' => 'US',
    'postalCode' => '123456',
    'emails' => [
        [
            'label' => 'main',
            'value' => 'johndoe@testemail.com',
            'primary' => true,
        ],
        [
            'label' => 'secondary',
            'value' => 'otheremail@testemail.com',
        ],
    ],
    'phoneNumbers' => [
        [
            'label' => 'work',
            'value' => '+123456789',
            'primary' => true,
        ],
        [
            'label' => 'home',
            'value' => '+9874654321',
        ],
    ],
]);

try {
    $customer = $client->customers()->create($customerForm);
} catch (Rebilly\\Http\\Exception\\DataValidationException $e) {
    print_r($e->getValidationErrors());
}
",
          },
          {
            "lang": "JavaScript",
            "source": "// first set the properties for the new customer
const data = {
    primaryAddress: {
        firstName: 'John',
        lastName: 'Doe',
        emails: [{
            label: 'main',
            value: 'john.doe+test@grr.la',
            primary: true
        }],
    }
};

// the ID is optional
const firstCustomer = await api.customers.create({data});

// or you can provide one
const secondCustomer = await api.customers.create({id: 'my-second-id', data});",
