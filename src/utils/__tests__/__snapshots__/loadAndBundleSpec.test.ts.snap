      "Allowlist": {
        "description": "Risk score allowlist record.",
        "properties": {
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "id": {
            "description": "ID of the allowlist record.",
            "example": "rsal_0YVF9605RKC62BP14NE2R7V2XT",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "type": {
            "description": "Type of data to exclude from risk score checks.
Data types that are added to this field are excluded from risk score checks and are not added to blocklists.",
            "enum": [
              "address",
              "bank-account",
              "bin",
              "country",
              "customer-id",
              "email",
              "email-domain",
              "fingerprint",
              "ip-address",
              "payment-card",
            ],
            "type": "string",
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
          "value": {
            "description": "Value of the allowlist record.",
            "type": "string",
          },
        },
        "required": [
          "type",
          "value",
        ],
        "type": "object",
      },
      "AlternativeInstrument": {
        "properties": {
          "_embedded": {
            "description": "Embedded objects that are requested by the \`expand\` query parameter.",
            "properties": {
              "customer": {
                "type": "object",
              },
            },
            "readOnly": true,
            "type": "object",
          },
          "_links": {
            "description": "Related links.",
            "items": {
              "properties": {
                "href": {
                  "description": "Link URL.",
                  "type": "string",
                },
                "rel": {
                  "description": "Type of link.",
                  "enum": [
                    "self",
                    "customer",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "billingAddress": {
            "$ref": "#/components/schemas/ContactObject",
            "description": "Billing address of the user that is associated with the payment instrument.",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "customFields": {
            "$ref": "#/components/schemas/ResourceCustomFields",
          },
          "customerId": {
            "$ref": "#/components/schemas/CustomerId",
          },
          "id": {
            "description": "ID of the payment instrument.",
            "example": "inst_0YVB8KPKNXCBR9EDX7JHSED75N",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "method": {
            "allOf": [
              {
                "$ref": "#/components/schemas/AlternativePaymentMethods",
              },
              {
                "not": {
                  "enum": [
                    "payment-card",
                    "paypal",
                    "ach",
                    "echeck",
                    "Khelocard",
                  ],
                },
              },
            ],
            "description": "Payment method of the payment instrument.",
          },
          "referenceData": {
            "additionalProperties": {
              "type": "string",
            },
            "description": "Payment instrument reference data.",
            "example": {
              "gatewayTransactionId": "GAT123",
            },
            "type": "object",
          },
          "revision": {
            "description": "Number of times the payment instrument data has been modified.

Use this value when analyzing webhook data to determine if a change must take precedence over the current representation.",
            "readOnly": true,
            "type": "integer",
          },
          "riskMetadata": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/RiskMetadata",
              },
              {
                "type": "null",
              },
            ],
          },
          "status": {
            "description": "Payment instrument status.",
            "enum": [
              "active",
              "deactivated",
            ],
            "readOnly": true,
            "type": "string",
          },
          "stickyGatewayAccountId": {
            "description": "ID of the sticky gateway account.
All future payments are processed by this gateway account.

For more information,
see [Gateway routing](https://www.rebilly.com/docs/settings/intelligent-payment-routing/#sticky-gateway-accounts).",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
          "useAsBackup": {
            "$ref": "#/components/schemas/UseAsBackup",
          },
        },
        "required": [
          "method",
          "customerId",
          "billingAddress",
        ],
        "title": "Alternative instrument",
        "type": "object",
      },
      "AlternativePaymentInstrument": {
        "description": "Alternative payment method instrument.

To use this payment instrument for automatic subscription renewals,
and for transactions when no specific payment instrument is provided by the user,
set this as the default payment instrument.",
