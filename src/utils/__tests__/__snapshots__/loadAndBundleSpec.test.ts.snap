      "Conflict": {
        "allOf": [
          {
            "title": "Conflict",
          },
          {
            "properties": {
              "status": {
                "description": "HTTP status code.",
                "maximum": 409,
                "minimum": 409,
                "type": "integer",
              },
            },
            "type": "object",
          },
          {
            "$ref": "#/components/schemas/BaseProblem",
          },
        ],
      },
      "ContactEmails": {
        "description": "List of email addresses associated with the contact.",
        "items": {
          "properties": {
            "label": {
              "description": "Email label or name.",
              "example": "main",
              "maxLength": 45,
              "type": "string",
            },
            "primary": {
              "description": "Specifies if the email address is the contact's primary email address.",
              "example": true,
              "type": "boolean",
            },
            "value": {
              "description": "Email address value.",
              "example": "rebilly@example.com",
              "format": "email",
              "maxLength": 255,
              "type": "string",
            },
          },
          "required": [
            "label",
            "value",
          ],
          "type": "object",
        },
        "type": "array",
      },
      "ContactObject": {
        "description": "Contact's information.",
        "properties": {
          "address": {
            "description": "First line of the contact's street address.",
            "example": "36 Craven St",
            "maxLength": 60,
            "pattern": "^[\\w\\s\\-\\/\\p{L},.#;:()'&]+$",
            "type": [
              "string",
              "null",
            ],
          },
          "address2": {
            "description": "Second line of the contact's street address.",
            "maxLength": 60,
            "pattern": "^[\\w\\s\\-\\/\\p{L},.#;:()'&]+$",
            "type": [
              "string",
              "null",
            ],
          },
          "city": {
            "description": "Contact's city of residence.",
            "example": "Austin",
            "maxLength": 45,
            "pattern": "^[\\w\\s\\-\\p{L},.']+$",
            "type": [
              "string",
              "null",
            ],
          },
          "country": {
            "description": "Contact's country of residence in ISO 3166 alpha-2 country code.
For examples, see [ISO.org](https://www.iso.org/obp/ui/#search/code/).",
            "example": "GB",
            "maxLength": 2,
            "pattern": "^[A-Z]{2}$",
            "type": [
              "string",
              "null",
            ],
          },
          "dob": {
            "description": "Contact's date of birth in ISO-8601 \`YYYY-MM-DD\` format.",
            "example": "1980-04-01",
            "format": "date",
            "type": [
              "string",
              "null",
            ],
          },
          "emails": {
            "$ref": "#/components/schemas/ContactEmails",
          },
          "firstName": {
            "description": "Contact's first name.",
            "example": "Benjamin",
            "maxLength": 45,
            "pattern": "^[\\w\\s\\-\\p{L},.']+$",
            "type": [
              "string",
              "null",
            ],
          },
          "hash": {
            "description": "Use this value to compare contacts for identical attribute values.",
            "example": "056ae6d97c788b9e98b049ebafd7b229bf852221",
            "maxLength": 40,
            "readOnly": true,
            "type": "string",
          },
          "jobTitle": {
            "description": "Contact's job title.",
            "example": "CEO",
            "maxLength": 255,
            "pattern": "^[\\w\\s\\-\\/\\p{L},.#;:()']+$",
            "type": [
              "string",
              "null",
            ],
          },
          "lastName": {
            "description": "Contact's last name.",
            "example": "Franklin",
            "maxLength": 45,
            "pattern": "^[\\w\\s\\-\\p{L},.']+$",
            "type": [
              "string",
              "null",
            ],
          },
          "organization": {
            "description": "Contact's organization.",
            "example": "Rebilly",
            "maxLength": 255,
            "pattern": "^[\\w\\s\\-\\p{L},.'&]+$",
            "type": [
              "string",
              "null",
            ],
          },
          "phoneNumbers": {
            "$ref": "#/components/schemas/ContactPhoneNumbers",
          },
          "postalCode": {
            "description": "Contact's postal code.",
            "example": "WC2N 5NF",
            "maxLength": 10,
            "pattern": "^[\\w\\s\\-]+$",
            "type": [
              "string",
              "null",
            ],
          },
          "region": {
            "description": "Contact's region of residence.",
            "example": "Texas",
            "maxLength": 45,
            "pattern": "^[\\w\\s\\-\\/\\p{L},.#;:()']+$",
            "type": [
              "string",
              "null",
            ],
          },
        },
        "type": "object",
      },
      "ContactPhoneNumbers": {
        "description": "List of phone numbers associated with the contact.",
        "items": {
          "properties": {
            "label": {
              "description": "Phone number label or name.",
              "example": "main",
              "maxLength": 45,
              "type": "string",
            },
            "primary": {
              "description": "Specifies if the phone number is the contact's primary phone number.",
              "example": true,
              "type": "boolean",
            },
            "value": {
              "description": "Phone number value.",
              "example": "512-710-1640",
              "maxLength": 50,
              "type": "string",
            },
          },
          "required": [
            "label",
            "value",
          ],
          "type": "object",
        },
        "type": "array",
      },
      "Country": {
        "description": "ISO 3166 alpha-2 country code. For examples, see [ISO.org](https://www.iso.org/obp/ui/#search/code/).",
        "example": "US",
        "pattern": "^[A-Z]{2}$",
        "type": "string",
      },
      "Coupon": {
        "description": "Coupons and discounts.",
        "properties": {
          "_links": {
            "$ref": "#/components/schemas/SelfLink",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "description": {
            "description": "Description of the coupon. Use this field to provide an invoice discount item description.

If this field is empty, the invoice discount item description uses the related coupon ID, in the following format:
\`Coupon "COUPON-ID"\`.",
            "type": "string",
            "x-basic": true,
          },
          "discount": {
            "$ref": "#/components/schemas/Discount",
          },
          "expiredTime": {
            "description": "Date and time when the coupon expires.",
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
            "x-basic": true,
            "x-label": "Valid until",
            "x-sortable": true,
          },
          "id": {
            "description": "ID of the coupon. This value is also known as the coupon redemption code.",
            "example": "cpn_0YVCNKF81GD778N4YNVGDJK558",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "issuedTime": {
            "description": "Date and time when the coupon is issued.
This value may also be described as start time of the coupon.",
            "format": "date-time",
            "type": "string",
            "x-basic": true,
            "x-label": "Valid from",
            "x-sortable": true,
          },
          "redemptionsCount": {
            "description": "Total number of times that a coupon is redeemed.",
            "minimum": 0,
            "readOnly": true,
            "type": "integer",
          },
          "restrictions": {
            "description": "Coupon restrictions.",
            "items": {
              "$ref": "#/components/schemas/CouponRestriction",
            },
            "type": "array",
          },
          "revision": {
            "description": "Number of times the coupon data has been modified.

Use the revision number when analyzing webhook data to
determine if a change should take precedence over the current
representation.",
            "readOnly": true,
            "type": "integer",
          },
          "status": {
            "description": "Specifies the current status of the coupon.",
            "enum": [
              "draft",
              "issued",
              "expired",
            ],
            "readOnly": true,
            "type": "string",
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
        },
        "required": [
          "discount",
          "issuedTime",
        ],
        "type": "object",
      },
      "CouponExpiration": {
        "properties": {
          "expiredTime": {
            "description": "Date and time when the coupon expires.
This value must be greater than the \`issuedTime\` value.
If this field contains a null or empty string, the coupon expires immediately.",
            "format": "date-time",
            "type": "string",
          },
        },
        "required": [
          "expiredTime",
        ],
        "type": "object",
      },
      "CouponRedemption": {
        "description": "Coupon redemption log.",
        "properties": {
          "_links": {
            "description": "Related links.",
            "items": {
              "properties": {
                "href": {
                  "description": "Link URL.",
                  "type": "string",
                },
                "rel": {
                  "description": "Type of link.",
                  "enum": [
                    "self",
                    "customer",
                    "coupon",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "additionalRestrictions": {
            "description": "Additional coupon redemption restrictions.",
            "items": {
              "$ref": "#/components/schemas/RedemptionRestriction",
            },
            "type": "array",
          },
          "canceledTime": {
            "description": "Date and time when the coupon is canceled.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
            "x-sortable": true,
          },
          "couponId": {
            "description": "ID of the coupon.",
            "example": "cpn_0YVCNKF81GD778N4YNVGDJK558",
            "maxLength": 50,
            "type": "string",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "customerId": {
            "$ref": "#/components/schemas/CustomerId",
          },
          "id": {
            "description": "Unique resource ID.",
            "example": "cpn_rdm_0YVCNKF81GD778N4YNVGDJK558",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
        },
        "type": "object",
      },
      "CouponRestriction": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/CouponRestrictionDiscountPerRedemption",
          },
          {
            "$ref": "#/components/schemas/CouponRestrictionExclusiveApplication",
          },
          {
            "$ref": "#/components/schemas/CouponRestrictionMinimumOrderAmount",
          },
          {
            "$ref": "#/components/schemas/CouponRestrictionPaidByTime",
          },
          {
            "$ref": "#/components/schemas/CouponRestrictionRedemptionsPerCustomer",
          },
          {
            "$ref": "#/components/schemas/CouponRestrictionRestrictToBxgy",
          },
          {
            "$ref": "#/components/schemas/CouponRestrictionRestrictToCountries",
          },
          {
            "$ref": "#/components/schemas/CouponRestrictionRestrictToCustomerTags",
          },
          {
            "$ref": "#/components/schemas/CouponRestrictionRestrictToCustomers",
          },
          {
            "$ref": "#/components/schemas/CouponRestrictionRestrictToInvoices",
          },
          {
            "$ref": "#/components/schemas/CouponRestrictionRestrictToPlans",
          },
          {
            "$ref": "#/components/schemas/CouponRestrictionRestrictToProducts",
          },
          {
            "$ref": "#/components/schemas/CouponRestrictionRestrictToSubscriptions",
          },
          {
            "$ref": "#/components/schemas/CouponRestrictionTotalRedemptions",
          },
        ],
        "description": "Coupon restrictions.",
        "discriminator": {
          "mapping": {
            "discounts-per-redemption": "#/components/schemas/CouponRestrictionDiscountPerRedemption",
            "minimum-order-amount": "#/components/schemas/CouponRestrictionMinimumOrderAmount",
            "paid-by-time": "#/components/schemas/CouponRestrictionPaidByTime",
            "redemptions-per-customer": "#/components/schemas/CouponRestrictionRedemptionsPerCustomer",
            "restrict-to-bxgy": "#/components/schemas/CouponRestrictionRestrictToBxgy",
            "restrict-to-countries": "#/components/schemas/CouponRestrictionRestrictToCountries",
            "restrict-to-customer-tags": "#/components/schemas/CouponRestrictionRestrictToCustomerTags",
            "restrict-to-customers": "#/components/schemas/CouponRestrictionRestrictToCustomers",
            "restrict-to-exclusive-application": "#/components/schemas/CouponRestrictionExclusiveApplication",
            "restrict-to-invoices": "#/components/schemas/CouponRestrictionRestrictToInvoices",
            "restrict-to-plans": "#/components/schemas/CouponRestrictionRestrictToPlans",
            "restrict-to-products": "#/components/schemas/CouponRestrictionRestrictToProducts",
            "restrict-to-subscriptions": "#/components/schemas/CouponRestrictionRestrictToSubscriptions",
            "total-redemptions": "#/components/schemas/CouponRestrictionTotalRedemptions",
          },
          "propertyName": "type",
        },
        "type": "object",
      },
      "CouponRestrictionDiscountPerRedemption": {
        "description": "Restricts the number of times that the coupon can be applied by one
redemption. For example, use this restriction to configure a coupon
that can only be applied to the first subscription renewal of a
particular product.",
        "properties": {
          "quantity": {
            "description": "Permitted number of discounts per redemption.",
            "type": "integer",
          },
          "type": {
            "description": "Type of coupon restriction.",
            "enum": [
              "discounts-per-redemption",
            ],
            "type": "string",
          },
        },
        "required": [
          "type",
          "quantity",
        ],
        "type": "object",
      },
      "CouponRestrictionExclusiveApplication": {
        "description": "Restricts a coupon so that it cannot be used in combination with other coupons.
If more than one coupon is active, a coupon with this restriction is only applied if it provides a larger discount than the other coupons combined.
If a coupon with this restriction is applied, all other coupons are removed.",
        "properties": {
          "type": {
            "description": "Type of coupon restriction.",
            "enum": [
              "restrict-to-exclusive-application",
            ],
            "type": "string",
          },
        },
        "required": [
          "type",
        ],
        "type": "object",
      },
      "CouponRestrictionMinimumOrderAmount": {
        "description": "Specifies a minimum order amount for a coupon application. For
example, if the restriction amount is $20, the coupon is only
applied to invoices with a total amount of $20 or more.",
        "properties": {
          "amount": {
            "description": "Minimum order quantity that is required to apply the coupon.",
            "type": "integer",
          },
          "currency": {
            "$ref": "#/components/schemas/CurrencyCode",
          },
          "type": {
            "description": "Type of coupon restriction.",
            "enum": [
              "minimum-order-amount",
            ],
            "type": "string",
          },
        },
        "required": [
          "type",
          "amount",
          "currency",
        ],
        "type": "object",
      },
      "CouponRestrictionPaidByTime": {
        "description": "Specifies a date and time at which a coupon redemption expires if the invoice is not paid.",
        "properties": {
          "time": {
            "description": "Date and time when a coupon redemption is no longer valid, and the coupon is removed from unpaid invoices if applied.

> **Note:** This date-time cannot be changed.",
            "format": "date-time",
            "type": "string",
          },
          "type": {
            "description": "Type of coupon restriction.",
            "enum": [
              "paid-by-time",
            ],
            "type": "string",
          },
        },
        "required": [
          "type",
          "time",
        ],
        "type": "object",
      },
      "CouponRestrictionRedemptionsPerCustomer": {
        "description": "Restricts the number of times that a coupon can be redeemed by one
customer. For example, use this restriction to limit the number of
redemptions to one per customer.",
        "properties": {
          "quantity": {
            "description": "Permitted number of redemptions per customer.",
            "type": "integer",
          },
          "type": {
            "description": "Type of coupon restriction.",
            "enum": [
              "redemptions-per-customer",
            ],
            "type": "string",
          },
        },
        "required": [
          "type",
          "quantity",
        ],
        "type": "object",
      },
      "CouponRestrictionRestrictToBxgy": {
        "description": "Provides "buy X get Y" promotions.
These promotions incentivize new customers to buy and also reward existing customers.
This restriction type enables you to add discounted plans to an invoice when a certain quantity of other plans are purchased.
For example, if a customer buys two or more books, they get one free bookmark.",
        "properties": {
          "buy": {
            "description": "One or more plan and quantity definitions that must be purchased to receive all plans and quantities that are defined in the \`get\` instruction.",
            "items": {
              "properties": {
                "planId": {
                  "description": "Plan ID of the item being purchased.",
                  "example": "plan_0YV7DENSVGDBW9S71XZNNYYQ0X",
                  "maxLength": 50,
                  "type": "string",
                },
                "quantity": {
                  "description": "Total quantity of the associated plan ID that must be purchased for this restriction to apply.",
                  "minimum": 1,
                  "type": "integer",
                },
              },
              "required": [
                "planId",
                "quantity",
              ],
              "type": "object",
            },
            "minItems": 1,
            "type": "array",
          },
          "get": {
            "description": "One or more plan and quantity definitions that are added to a purchase if all definitions in the \`buy\` condition are met.",
            "items": {
              "properties": {
                "planId": {
                  "description": "Plan ID of the item that is to be received by the customer.",
                  "example": "plan_0YV7DENSVGDBW9S71XZNNYYQ0X",
                  "maxLength": 50,
                  "type": "string",
                },
                "quantity": {
                  "description": "Total quantity of the associated plan ID that is to be received by the customer.",
                  "minimum": 1,
                  "type": "integer",
                },
              },
              "required": [
                "planId",
                "quantity",
              ],
              "type": "object",
            },
            "minItems": 1,
            "type": "array",
          },
          "type": {
            "description": "Type of coupon restriction.",
            "enum": [
              "restrict-to-bxgy",
            ],
            "type": "string",
          },
        },
        "required": [
          "type",
          "buy",
          "get",
        ],
        "type": "object",
      },
      "CouponRestrictionRestrictToCountries": {
        "description": "Restricts a coupon for use in specific countries.",
        "properties": {
          "countries": {
            "description": "Countries where the coupon can be applied, in ISO Alpha-2 code format.
For examples, see [ISO.org](https://www.iso.org/obp/ui/#search/code/).",
            "items": {
              "pattern": "^[A-Z]{2}$",
              "type": "string",
            },
            "type": "array",
          },
          "type": {
            "description": "Type of coupon restriction.",
            "enum": [
              "restrict-to-countries",
            ],
            "type": "string",
          },
        },
        "required": [
          "type",
          "countries",
        ],
        "type": "object",
      },
      "CouponRestrictionRestrictToCustomerTags": {
        "description": "Restricts a coupon to customers with specific tags.",
        "properties": {
          "requireAllTags": {
            "description": "Determines the behavior for checking customer tags.",
            "enum": [
              true,
              false,
            ],
            "type": "boolean",
            "x-enumDescriptions": {
              "false": "Customer must have at least one of the listed tags to redeem a coupon.",
              "true": "Customer must have all listed tags to redeem a coupon.",
            },
          },
          "tags": {
            "description": "Customer tags on which a coupon can be applied.",
            "items": {
              "type": "string",
            },
            "type": "array",
          },
          "type": {
            "description": "Type of coupon restriction.",
            "enum": [
              "restrict-to-customer-tags",
            ],
            "type": "string",
          },
        },
        "required": [
          "type",
          "tags",
          "requireAllTags",
        ],
        "type": "object",
      },
      "CouponRestrictionRestrictToCustomers": {
        "description": "Restricts a coupon to specific customers.",
        "properties": {
          "customerIds": {
            "description": "Customer IDs on which a coupon can be applied.",
            "items": {
              "type": "string",
            },
            "type": "array",
          },
          "type": {
            "description": "Type of coupon restriction.",
            "enum": [
              "restrict-to-customers",
            ],
            "type": "string",
          },
        },
        "required": [
          "type",
          "customerIds",
        ],
        "type": "object",
      },
      "CouponRestrictionRestrictToInvoices": {
        "description": "Restricts a coupon to specific invoices.",
        "properties": {
          "invoiceIds": {
            "description": "Invoice IDs on which a coupon can be applied.",
            "items": {
              "type": "string",
            },
            "type": "array",
          },
          "type": {
            "description": "Type of coupon restriction.",
            "enum": [
