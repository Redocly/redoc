      "Fee": {
        "properties": {
          "_links": {
            "$ref": "#/components/schemas/SelfLink",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "filter": {
            "description": "Filter that is based on the properties of the transaction and used to determine when to apply the fee.",
            "example": "type:sale,capture;result:approved",
            "maxLength": 255,
            "minLength": 1,
            "type": [
              "string",
              "null",
            ],
          },
          "formula": {
            "$ref": "#/components/schemas/FeeFormula",
          },
          "id": {
            "description": "ID of the fee.",
            "example": "fee_01GQT145JX3XBRJ8K812Y3GRE9",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "name": {
            "description": "Name of the fee.",
            "example": "A gateway fee",
            "maxLength": 255,
            "minLength": 1,
            "type": "string",
          },
          "settlementSettings": {
            "description": "Fee settlement settings.
This value overrides the gateway account financial settings of the transaction.",
            "oneOf": [
              {
                "$ref": "#/components/schemas/SettlementSettings",
              },
              {
                "type": "null",
              },
            ],
          },
          "type": {
            "description": "Type of fee.",
            "enum": [
              "buy",
              "sell",
            ],
            "type": "string",
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
        },
        "required": [
          "type",
          "name",
          "formula",
        ],
        "type": "object",
      },
      "FeeFormula": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/FixedFeeFormula",
          },
          {
            "$ref": "#/components/schemas/PercentageFeeFormula",
          },
        ],
        "description": "Formula that is used to calculate the fee.",
        "discriminator": {
          "mapping": {
            "fixed-fee": "#/components/schemas/FixedFeeFormula",
            "percentage": "#/components/schemas/PercentageFeeFormula",
          },
          "propertyName": "type",
        },
        "type": "object",
      },
      "File": {
        "properties": {
          "_links": {
            "description": "Related links.",
            "items": {
              "properties": {
                "href": {
                  "description": "Link URL.",
                  "type": "string",
                },
                "rel": {
                  "description": "Type of link.",
                  "enum": [
                    "self",
                    "download",
                    "signedLink",
                    "permalink",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "description": {
            "description": "Description of the file.",
            "type": "string",
          },
          "exifData": {
            "description": "Collection of EXIF tags contained in the image metadata. This field applicable to images only.",
            "example": {
              "FileSize": 120,
              "Software": "GIMP 2.4.5",
            },
            "readOnly": true,
            "type": [
              "object",
              "null",
            ],
          },
          "extension": {
            "description": "File extension.",
            "type": "string",
          },
          "height": {
            "description": "Image height. This field applicable to images only.",
            "readOnly": true,
            "type": "integer",
          },
          "id": {
            "description": "ID of the file.",
            "example": "file_0YV7HZ7KDCC5WBV9Q7WRKG1H6N",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "isPublic": {
            "description": "Specifies if the file is available publicly without authentication.
If this value is \`true\`, the permalink in the \`_links\` section contains the public URL.",
            "type": "boolean",
          },
          "mime": {
            "description": "MIME type of the file.",
            "enum": [
              "image/png",
              "image/jpeg",
              "image/gif",
              "application/pdf",
            ],
            "readOnly": true,
            "type": "string",
          },
          "name": {
            "description": "Original file name.",
            "type": "string",
          },
          "sha1": {
            "description": "Hash sum of the file.",
            "readOnly": true,
            "type": "string",
          },
          "size": {
            "description": "File size, in bytes.",
            "readOnly": true,
            "type": "integer",
          },
          "sourceType": {
            "description": "Source of the file.",
            "enum": [
              "upload",
              "camera",
              "organization-export",
              "organization-closure-export",
              null,
            ],
            "example": "upload",
            "type": [
              "string",
              "null",
            ],
          },
          "tags": {
            "description": "List of tags associated with the file.",
            "items": {
              "type": "string",
            },
            "type": "array",
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
          "width": {
            "description": "Image width. This field applicable to images only.",
            "readOnly": true,
            "type": "integer",
          },
        },
        "type": "object",
      },
      "FileCreateFromInline": {
        "properties": {
          "description": {
            "description": "Description of the file.",
            "example": "My file description",
            "type": "string",
          },
          "file": {
            "description": "File in base64 encoded format.",
            "example": "R0lGODlhAQABAIAAAAUEBAAAACwAAAAAAQABAAACAkQBADs=",
            "type": "string",
          },
          "isPublic": {
            "description": "Specifies if the file is available publicly without authentication.
If this value is \`true\`, the permalink in the \`_links\` section contains the public URL.",
            "example": false,
            "type": "boolean",
          },
          "name": {
            "description": "File name used for downloading.",
            "example": "logo.png",
            "type": "string",
          },
          "sourceType": {
            "description": "Source of the file.",
            "enum": [
              "upload",
              "camera",
            ],
            "example": "upload",
            "type": [
              "string",
              "null",
            ],
          },
          "tags": {
            "description": "List of tags associated with the file.",
            "example": [
              "test",
              "tags",
            ],
            "items": {
              "type": "string",
            },
            "type": "array",
          },
        },
        "required": [
          "file",
        ],
        "type": "object",
      },
      "FileCreateFromUrl": {
        "properties": {
          "description": {
            "description": "Description of the file.",
            "example": "My file description",
            "type": "string",
          },
          "isPublic": {
            "description": "Specifies if the file is available publicly without authentication.
If this value is \`true\`, the permalink in the \`_links\` section contains the public URL.",
            "example": false,
            "type": "boolean",
          },
          "name": {
            "description": "File name used for downloading.",
            "example": "logo.png",
            "type": "string",
          },
          "sourceType": {
            "description": "Source of the file.",
            "enum": [
              "upload",
              "camera",
            ],
            "example": "upload",
            "type": [
              "string",
              "null",
            ],
          },
          "tags": {
            "description": "List of tags associated with the file.",
            "example": [
              "test",
              "tags",
            ],
            "items": {
              "type": "string",
            },
            "type": "array",
          },
          "url": {
            "description": "URL of the file to upload.",
            "example": "https://blog.rebilly.com/wp-content/uploads/2017/09/rb_LogoInverted_Small.png",
            "type": "string",
          },
        },
        "required": [
          "url",
        ],
        "type": "object",
      },
      "FixedFeeFormula": {
        "properties": {
          "amount": {
            "description": "Amount of the fee.",
            "example": 10,
            "format": "double",
            "type": "number",
            "x-type": "Money",
          },
          "currency": {
            "$ref": "#/components/schemas/CurrencyCode",
