            "enum": [
              "resend-email",
            ],
            "type": "string",
          },
          "messageId": {
            "$ref": "#/components/schemas/ResourceId",
          },
        },
        "readOnly": true,
        "type": "object",
      },
      "ResetPasswordToken": {
        "properties": {
          "_links": {
            "$ref": "#/components/schemas/SelfLink",
          },
          "credentialId": {
            "description": "Credential ID associated with the token.",
            "readOnly": true,
            "type": "string",
          },
          "expiredTime": {
            "description": "Date and time when the password expires.",
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
          },
          "token": {
            "description": "ID of the token.",
            "readOnly": true,
            "type": "string",
          },
          "username": {
            "description": "Username associated with the token.",
            "type": "string",
          },
        },
        "required": [
          "username",
        ],
        "type": "object",
      },
      "ResourceCustomFields": {
        "default": {},
        "description": "Use custom fields to extend a resource scheme to include custom data that is not provided as a common field.
For more information, see [Custom fields](https://www.rebilly.com/catalog/all/custom-fields).",
        "example": {
          "foo": "bar",
        },
        "type": "object",
      },
      "ResourceId": {
        "description": "Unique resource ID.",
        "example": "4f6cf35x-2c4y-483z-a0a9-158621f77a21",
        "maxLength": 50,
        "type": "string",
      },
      "RiskMetadata": {
        "description": "Risk metadata used for 3D Secure and risk scoring.",
        "properties": {
          "accuracyRadius": {
            "description": "Accuracy radius of the specified IP address, in kilometers.",
            "readOnly": true,
            "type": [
              "integer",
              "null",
            ],
          },
          "billingAddressVelocity": {
            "description": "Number of transactions for this billing address in the last 24 hours.",
            "readOnly": true,
            "type": "integer",
          },
          "browserData": {
            "description": "Browser data used for 3D Secure and risk scoring.",
            "properties": {
              "colorDepth": {
                "description": "Browser color depth in bits per pixel. This value is obtained using the \`screen.colorDepth\` property.",
                "example": 24,
                "maximum": 48,
                "minimum": 1,
                "type": "integer",
              },
              "isAdBlockEnabled": {
                "description": "Specifies if the usage of ad block has been detected in the browser.",
                "type": "boolean",
              },
              "isJavaEnabled": {
                "description": "Specifies if Java is enabled in a browser. This value is obtained from the \`navigator.javaEnabled\` property.",
                "type": "boolean",
              },
              "language": {
                "description": "Browser language settings. This value is obtained from the \`navigator.language\` property.",
                "example": "en-US",
                "maxLength": 8,
                "type": "string",
              },
              "screenHeight": {
                "description": "Height of the browser screen. This value is obtained from the \`screen.height\` property.",
                "example": 1080,
                "maximum": 65535,
                "minimum": 0,
                "type": "integer",
              },
              "screenWidth": {
                "description": "Width of the browser screen. This value is obtained from the \`screen.width\` property.",
                "example": 1920,
                "maximum": 65535,
                "minimum": 0,
                "type": "integer",
              },
              "timeZoneOffset": {
                "description": "Browser time zone offset in minutes from UTC.
A positive offset indicates that the local time is behind UTC.
A negative offset indicates that the local time is ahead of UTC.
You can find this value using the \`(new Date()).getTimezoneOffset()\` property.",
                "example": 300,
                "maximum": 1410,
                "minimum": -1410,
                "type": "integer",
              },
            },
            "required": [
              "colorDepth",
              "isJavaEnabled",
              "language",
              "screenWidth",
              "screenHeight",
              "timeZoneOffset",
            ],
            "type": [
              "object",
              "null",
            ],
          },
          "city": {
            "description": "City of the specified IP address.",
            "example": "New York",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "country": {
            "description": "Country ISO Alpha-2 code of the specified IP address.",
            "example": "US",
            "maxLength": 2,
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "declinedPaymentInstrumentVelocity": {
            "description": "Number of declined transactions for this payment instrument fingerprint in the last 24 hours.",
            "readOnly": true,
            "type": "integer",
          },
          "deviceVelocity": {
            "description": "Number of transactions for this device, based on fingerprint, in the last 24 hours.",
            "readOnly": true,
            "type": "integer",
          },
          "distance": {
            "description": "Distance between the customer's IP address and the billing address geolocation, in kilometers.",
            "readOnly": true,
            "type": [
              "integer",
              "null",
            ],
          },
          "emailVelocity": {
            "description": "Number of transactions for this email address in the last 24 hours.",
            "readOnly": true,
            "type": "integer",
          },
          "extraData": {
            "description": "Third-party data used for risk scoring.",
            "properties": {
              "kountFraudSessionId": {
                "description": "Alpha-numeric \`fraudSessionId\` as provided by the Kount SDK.",
                "example": "abcdefg12345abababab123456789012",
                "maximum": 32,
                "minimum": 10,
                "type": "string",
              },
              "payPalMerchantSessionId": {
                "description": "PayPal \`MerchantSessionID\` as generated by the PayPal Fraudnet SDK.",
                "example": "dd65ratxc5qv15iph3vyoq7l6davuowa",
                "maximum": 64,
                "minimum": 1,
                "type": "string",
              },
              "threatMetrixSessionId": {
                "description": "Temporary identifier that is unique to the visitor's session and passed to ThreatMetrix.",
                "example": "dd65ratxc5qv15iph3vyoq7l6davuowadd65ratxc5qv15iph3vyoq7l6davuowa",
                "maximum": 128,
                "minimum": 1,
                "pattern": "[a-zA-Z0-9_-]+",
                "type": "string",
              },
            },
            "type": [
              "object",
              "null",
            ],
          },
          "fingerprint": {
            "description": "Customer's device fingerprint.
A device fingerprint is a unique token that is used to identify the customer.
The device fingerprint is generated based on device attributes, such as: hardware,
software, IP address, language, browser, and more.",
            "example": "pIUt3xbgX3l9g3YDiLbx",
            "maxLength": 50,
            "type": [
              "string",
              "null",
            ],
          },
          "hasFakeName": {
            "description": "Specifies if the holder name seems fake.",
            "readOnly": true,
            "type": "boolean",
          },
          "hasMismatchedBankCountry": {
            "description": "Specifies if the customer's bank country and geo-IP address are not the same.",
            "readOnly": true,
            "type": "boolean",
          },
          "hasMismatchedBillingAddressCountry": {
            "description": "Specifies if the customer's billing address country and geo-IP address are not the same.",
            "readOnly": true,
            "type": "boolean",
          },
          "hasMismatchedHolderName": {
            "description": "Specifies if the customer's billing address name and primary address name are not the same.",
            "readOnly": true,
            "type": "boolean",
          },
          "hasMismatchedTimeZone": {
            "description": "Specifies if the customer's browser time zone and the IP address associated time zone are not the same.",
            "readOnly": true,
            "type": "boolean",
          },
          "hostingName": {
            "description": "Name of the data center or hosting provider, if available.",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "httpHeaders": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/HttpHeaders",
              },
              {
                "type": "null",
              },
            ],
          },
          "ipAddress": {
            "description": "Customer's IP address.",
            "example": "93.92.91.90",
            "format": "ipv4 or ipv6",
            "type": [
              "string",
              "null",
            ],
          },
          "ipVelocity": {
            "description": "Number of transactions for this IP address in the last 24 hours.",
            "readOnly": true,
            "type": "integer",
          },
          "isHighRiskCountry": {
            "description": "Specifies if the geo-IP country, or the customer's billing country, is considered a high risk country.",
            "readOnly": true,
            "type": "boolean",
          },
          "isHosting": {
            "description": "Specifies if the customer's IP address is related to hosting.",
            "readOnly": true,
            "type": "boolean",
          },
          "isProxy": {
            "description": "Specifies if the customer's IP address is related to a proxy.",
            "readOnly": true,
            "type": "boolean",
          },
          "isTor": {
            "description": "Specifies if the customer's IP address is related to TOR.",
            "readOnly": true,
            "type": "boolean",
          },
          "isVpn": {
            "description": "Specifies if the customer's IP address is related to a VPN.",
            "readOnly": true,
            "type": "boolean",
          },
          "isp": {
            "description": "Internet Service Provider (ISP) name, if available.",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "latitude": {
            "description": "Latitude of the specified IP address.",
            "format": "double",
            "readOnly": true,
            "type": "number",
          },
          "longitude": {
            "description": "Longitude of the specified IP address.",
            "format": "double",
            "readOnly": true,
            "type": [
              "number",
              "null",
            ],
          },
          "paymentInstrumentApprovedTransactionCount": {
            "description": "Number of approved transactions for this payment instrument.",
            "readOnly": true,
            "type": "integer",
          },
          "paymentInstrumentVelocity": {
            "description": "Number of transactions for this payment instrument, based on fingerprint, in the last 24 hours.",
            "readOnly": true,
            "type": "integer",
          },
          "postalCode": {
            "description": "Postal code of the specified IP address.",
            "maxLength": 10,
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "region": {
            "description": "Region of the specified IP address.",
            "example": "NY",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "score": {
            "description": "Computed risk score based on IP risk data,
such as: \`isVpn\`, \`isTor\`, and \`isProxy\`.",
            "readOnly": true,
            "type": "integer",
          },
          "timeZone": {
            "description": "Time zone of the specified IP address.",
            "example": "America/New_York",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
        },
        "title": "Risk metadata",
        "type": "object",
      },
      "RiskScoreBlocklist": {
        "description": "Risk score blocklist configuration.",
        "properties": {
          "address": {
            "$ref": "#/components/schemas/RiskScoreBlocklistType",
            "description": "House number and ZIP code of the customer's address.",
          },
          "bank-account": {
            "$ref": "#/components/schemas/RiskScoreBlocklistType",
            "description": "Bank account being charged.",
          },
          "bin": {
            "$ref": "#/components/schemas/RiskScoreBlocklistType",
            "description": "Bank Identification Number (BIN) of the payment card being charged.",
          },
          "country": {
            "$ref": "#/components/schemas/RiskScoreBlocklistType",
            "description": "Country where the customer is making the purchase, and of the payment card billing address.",
          },
          "customer-id": {
            "$ref": "#/components/schemas/RiskScoreBlocklistType",
            "description": "Rebilly \`customerId\` of the customer making the purchase.",
          },
          "email": {
            "$ref": "#/components/schemas/RiskScoreBlocklistType",
            "description": "Email address of the customer making the purchase.",
          },
          "email-domain": {
            "$ref": "#/components/schemas/RiskScoreBlocklistType",
            "description": "Email address domain of the customer making the purchase.",
          },
          "fingerprint": {
            "$ref": "#/components/schemas/RiskScoreBlocklistType",
            "description": "Fingerprint of the user's device.
A device fingerprint is a unique token that is used to identify the user.
The device fingerprint is generated based on device attributes,
such as: hardware, software, IP address, language, browser, and more.",
          },
          "ip-address": {
            "$ref": "#/components/schemas/RiskScoreBlocklistType",
            "description": "IP address of the customer making the purchase.",
          },
          "payment-card": {
            "$ref": "#/components/schemas/RiskScoreBlocklistType",
            "description": "Payment card number being charged.",
          },
        },
        "type": "object",
      },
      "RiskScoreBlocklistType": {
        "properties": {
          "riskScoreThreshold": {
            "description": "Pass and fail threshold for the blocklist.",
            "type": "integer",
          },
          "ttl": {
            "description": "Amount of seconds a blocklist exists before it expires.
If value for this field is \`0\` then blocklist record never expires.",
            "type": "integer",
          },
        },
        "required": [
          "riskScoreThreshold",
          "ttl",
        ],
        "type": [
          "object",
          "null",
        ],
      },
      "RiskScoreBoolean": {
        "properties": {
          "value": {
            "description": "Value added to the risk score of the transaction.",
            "type": "integer",
          },
        },
        "required": [
          "value",
        ],
        "type": [
          "object",
          "null",
        ],
      },
      "RiskScoreBracket": {
        "properties": {
          "brackets": {
            "description": "Risk factor values range with corresponding risk score increment value. First matched bracket is applied.",
            "items": {
              "properties": {
                "end": {
                  "description": "Maximal risk factor value when condition is applied.",
                  "minimum": 1,
                  "type": "integer",
                },
                "start": {
                  "description": "Minimal risk factor value when condition is applied.",
                  "minimum": 0,
                  "type": "integer",
                },
                "value": {
                  "description": "Value added to the risk score of the transaction.",
                  "type": "integer",
                },
              },
              "required": [
                "start",
                "end",
                "value",
              ],
              "type": "object",
            },
            "minItems": 1,
            "type": "array",
          },
        },
        "required": [
          "brackets",
        ],
        "type": [
          "object",
          "null",
        ],
      },
      "RiskScoreRules": {
        "description": "Risk score rules.",
        "properties": {
          "billingAddressVelocity": {
            "$ref": "#/components/schemas/RiskScoreBracket",
            "description": "Number of transactions for this billing address in the last 24 hours.",
          },
          "declinedPaymentInstrumentVelocity": {
            "$ref": "#/components/schemas/RiskScoreBracket",
            "description": "Number of declined transactions for this payment instrument fingerprint in the last 24 hours.",
          },
          "deviceVelocity": {
            "$ref": "#/components/schemas/RiskScoreBracket",
            "description": "Number of transactions for this device, based on fingerprint, in the last 24 hours.",
          },
          "emailVelocity": {
            "$ref": "#/components/schemas/RiskScoreBracket",
            "description": "Number of transactions for this email address in the last 24 hours.",
          },
          "hasFakeName": {
            "$ref": "#/components/schemas/RiskScoreBoolean",
            "description": "Specifies whether the holder name seems fake.",
          },
          "hasMismatchedBankCountry": {
            "$ref": "#/components/schemas/RiskScoreBoolean",
            "description": "Specifies whether the customer's bank country and geo-IP address are not the same.",
          },
          "hasMismatchedBillingAddressCountry": {
            "$ref": "#/components/schemas/RiskScoreBoolean",
            "description": "Specifies whether the customer's billing address country and geo-IP address are not the same.",
          },
          "hasMismatchedHolderName": {
            "$ref": "#/components/schemas/RiskScoreBoolean",
            "description": "Specifies whether the customer's billing address name and primary address name are not the same.",
          },
          "hasMismatchedTimeZone": {
            "$ref": "#/components/schemas/RiskScoreBoolean",
            "description": "Specifies whether the customer's browser time zone and the IP address associated time zone are not the same.",
          },
          "ipVelocity": {
            "$ref": "#/components/schemas/RiskScoreBracket",
            "description": "Number of transactions for this IP address in the last 24 hours.",
          },
          "isHighRiskCountry": {
            "$ref": "#/components/schemas/RiskScoreBoolean",
            "description": "Specifies whether the geo-IP country, or the customer's billing country, is considered a high risk country.",
          },
          "isHosting": {
            "$ref": "#/components/schemas/RiskScoreBoolean",
            "description": "Specifies whether the customer's IP address is related to hosting.",
          },
          "isProxy": {
            "$ref": "#/components/schemas/RiskScoreBoolean",
            "description": "Specifies whether the customer's IP address is related to a proxy.",
          },
          "isTor": {
            "$ref": "#/components/schemas/RiskScoreBoolean",
            "description": "Specifies whether the customer's IP address is related to TOR.",
          },
          "isVpn": {
            "$ref": "#/components/schemas/RiskScoreBoolean",
            "description": "Specifies whether the customer's IP address is related to a VPN.",
          },
          "paymentInstrumentVelocity": {
            "$ref": "#/components/schemas/RiskScoreBracket",
            "description": "Number of transactions for this payment instrument, based on fingerprint, in the last 24 hours.",
          },
        },
        "required": [
          "isProxy",
          "isVpn",
          "isTor",
          "isHosting",
          "hasMismatchedBillingAddressCountry",
          "hasMismatchedBankCountry",
          "hasMismatchedTimeZone",
          "hasMismatchedHolderName",
          "hasFakeName",
          "isHighRiskCountry",
          "paymentInstrumentVelocity",
          "declinedPaymentInstrumentVelocity",
          "deviceVelocity",
          "ipVelocity",
          "emailVelocity",
          "billingAddressVelocity",
        ],
        "type": "object",
      },
      "RulesetRestoreTimelineAction": {
        "description": "Restore ruleset version.",
        "properties": {
          "action": {
            "enum": [
              "ruleset-restore",
            ],
            "type": "string",
          },
          "version": {
            "description": "Version of the ruleset to restore.",
            "type": "integer",
          },
        },
        "readOnly": true,
        "type": "object",
      },
      "SchedulingMethodDateInterval": {
        "properties": {
          "anchor": {
            "$ref": "#/components/schemas/PeriodAnchor",
          },
          "duration": {
            "description": "Number of time units.",
            "minimum": 1,
            "type": "integer",
          },
          "method": {
            "enum": [
              "date-interval",
            ],
            "type": "string",
          },
          "unit": {
            "description": "Unit of time.",
            "oneOf": [
              {
                "$ref": "#/components/schemas/TimeUnit",
              },
              {
                "$ref": "#/components/schemas/TimePluralUnit",
              },
            ],
          },
        },
        "required": [
          "duration",
          "unit",
          "method",
        ],
        "type": "object",
      },
      "SchedulingMethodDayOfMonth": {
        "properties": {
          "day": {
            "description": "Day of the month in which the event occurs.
If the month has less days, the last day of the month is selected.",
            "maximum": 31,
            "minimum": 1,
            "type": "integer",
          },
          "method": {
            "enum": [
              "day-of-month",
            ],
            "type": "string",
          },
          "time": {
            "$ref": "#/components/schemas/TimeIso8601Extended",
          },
        },
        "required": [
          "day",
          "method",
        ],
        "type": "object",
      },
      "SchedulingMethodDayOfWeek": {
        "properties": {
          "day": {
            "description": "Day of the week when the event occurs.",
            "enum": [
              "Sunday",
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday",
              "Saturday",
            ],
            "type": "string",
          },
          "method": {
            "enum": [
              "day-of-week",
            ],
            "type": "string",
          },
          "time": {
            "$ref": "#/components/schemas/TimeIso8601Extended",
          },
          "week": {
            "enum": [
              "next",
              "first-in-month",
              "last-in-month",
            ],
            "type": "string",
          },
        },
        "required": [
          "day",
          "week",
          "method",
        ],
        "type": "object",
      },
      "SchedulingMethodImmediately": {
        "properties": {
          "method": {
            "enum": [
              "immediately",
            ],
            "type": "string",
          },
        },
        "required": [
          "method",
        ],
        "type": "object",
      },
      "SchedulingMethodIntelligent": {
        "properties": {
          "duration": {
            "description": "Latest point in time at which the event should occur.
The event occurs at a random time between the initial time and duration time.",
            "minimum": 1,
            "type": "integer",
          },
          "method": {
            "enum": [
              "intelligent",
            ],
            "type": "string",
          },
          "unit": {
            "description": "Unit of time.",
            "oneOf": [
              {
                "$ref": "#/components/schemas/TimeUnit",
              },
              {
                "$ref": "#/components/schemas/TimePluralUnit",
              },
            ],
          },
        },
        "required": [
          "duration",
          "unit",
          "method",
        ],
        "type": "object",
      },
      "Search": {
        "properties": {
          "customers": {
            "description": "List of returned customers.",
            "items": {
              "$ref": "#/components/schemas/Customer",
            },
            "readOnly": true,
            "type": "array",
          },
          "invoices": {
            "description": "List of returned invoices.",
            "items": {
              "$ref": "#/components/schemas/Invoice",
            },
            "readOnly": true,
            "type": "array",
          },
          "orders": {
            "description": "List of returned orders.",
            "items": {
              "$ref": "#/components/schemas/SubscriptionOrOneTimeSale",
            },
            "readOnly": true,
            "type": "array",
          },
          "searched": {
            "description": "Names of searched resources.
Includes all searched resources.",
            "items": {
              "type": "string",
            },
            "readOnly": true,
            "type": "array",
          },
          "transactions": {
            "description": "List of returned transactions.",
            "items": {
              "$ref": "#/components/schemas/Transaction",
            },
            "readOnly": true,
            "type": "array",
          },
        },
        "type": "object",
      },
      "SelfLink": {
        "description": "Related links.",
        "items": {
          "properties": {
            "href": {
              "description": "Link URL.",
              "type": "string",
            },
            "rel": {
              "description": "Type of link.",
              "enum": [
                "self",
              ],
              "type": "string",
            },
          },
          "type": "object",
        },
        "readOnly": true,
        "type": "array",
      },
      "ServerTimestamp": {
        "description": "Read-only timestamp in ISO 8601 date-time format.",
        "format": "date-time",
        "readOnly": true,
        "type": "string",
      },
      "ServicePeriodAnchorInstruction": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/SchedulingMethodDayOfMonth",
          },
          {
            "$ref": "#/components/schemas/SchedulingMethodDayOfWeek",
          },
          {
            "$ref": "#/components/schemas/SchedulingMethodImmediately",
          },
        ],
        "default": {
          "method": "immediately",
        },
        "description": "Instruction for calculating the service period anchor.

The service period anchor is used, in conjunction with the subscription
start time, to calculate when the service period starts and ends.",
        "discriminator": {
          "mapping": {
            "day-of-month": "#/components/schemas/SchedulingMethodDayOfMonth",
            "day-of-week": "#/components/schemas/SchedulingMethodDayOfWeek",
            "immediately": "#/components/schemas/SchedulingMethodImmediately",
          },
          "propertyName": "method",
        },
        "type": "object",
      },
      "SettlementPeriod": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/SchedulingMethodDateInterval",
          },
          {
            "$ref": "#/components/schemas/SchedulingMethodImmediately",
          },
        ],
        "description": "Instruction for calculating the settlement time.
The settlement time and settlement period anchor are used
in conjunction with the transaction processed time,
to calculate the time in which the amount settles.",
        "discriminator": {
          "mapping": {
            "date-interval": "#/components/schemas/SchedulingMethodDateInterval",
            "immediately": "#/components/schemas/SchedulingMethodImmediately",
          },
          "propertyName": "method",
        },
        "type": "object",
      },
      "SettlementSettings": {
        "description": "Settlement settings.
Use these settings to set up settlement accounts.",
        "properties": {
          "advancedSettings": {
            "description": "Advanced settlement settings.
Use these settings to override either default settlement currency,
period, or both for the transactions matched a filter.",
            "items": {
              "properties": {
                "filter": {
                  "description": "Filter that is based on transaction properties and is used to determine when to apply the settings.",
                  "example": "currency:EUR,GBP",
                  "maxLength": 255,
                  "minLength": 1,
                  "type": "string",
                },
                "settlementCurrency": {
                  "$ref": "#/components/schemas/CurrencyCode",
                },
                "settlementPeriod": {
                  "$ref": "#/components/schemas/SettlementPeriod",
                },
              },
              "required": [
                "filter",
              ],
              "type": "object",
            },
            "type": "array",
          },
          "settlementCurrency": {
            "$ref": "#/components/schemas/CurrencyCode",
            "description": "Default settlement currency for all transactions.",
          },
          "settlementPeriod": {
            "$ref": "#/components/schemas/SettlementPeriod",
            "description": "Default settlement period for all transactions.",
          },
        },
        "required": [
          "settlementCurrency",
          "settlementPeriod",
        ],
        "type": "object",
      },
      "Shipping": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/ManualShipping",
          },
          {
            "$ref": "#/components/schemas/RebillyShipping",
          },
        ],
        "description": "Shipping settings.",
        "discriminator": {
          "mapping": {
            "manual": "#/components/schemas/ManualShipping",
            "rebilly": "#/components/schemas/RebillyShipping",
          },
          "propertyName": "calculator",
        },
        "type": "object",
      },
      "ShippingOption": {
        "properties": {
          "currency": {
            "$ref": "#/components/schemas/CurrencyCode",
          },
          "description": {
            "description": "Description of the shipping rate.",
            "type": [
              "string",
              "null",
            ],
          },
          "id": {
            "description": "ID of the shipping rate.",
            "example": "ship_rate_0YVDN408G4DQE9G1RV1QCFHJ3P",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "name": {
            "description": "Name of the shipping rate.",
            "type": "string",
          },
          "price": {
            "description": "Price of the shipping rate.
If \`price\` is \`0\`, shipping is free.",
            "format": "double",
            "type": "number",
          },
        },
        "required": [
          "name",
          "price",
          "currency",
        ],
        "type": "object",
      },
      "ShippingRate": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ShippingOption",
          },
          {
            "properties": {
              "_links": {
                "$ref": "#/components/schemas/SelfLink",
              },
              "createdTime": {
                "$ref": "#/components/schemas/CreatedTime",
              },
              "filter": {
                "default": "",
                "description": "Filter based on invoice properties that is used to determine when the rate is applicable.
If no filters are used, the rate is always applicable.",
                "example": "deliveryAddress.country:US,CA,RU;amount:100..1000",
                "type": "string",
              },
              "status": {
                "default": "active",
                "description": "Status of the shipping rate.
If \`status\` is \`inactive\` the shipping rate is not applied.",
                "enum": [
                  "active",
                  "inactive",
                ],
                "type": "string",
              },
              "updatedTime": {
                "$ref": "#/components/schemas/UpdatedTime",
              },
            },
          },
        ],
      },
      "ShowEddSearchLogsTimelineAction": {
        "description": "Show Enhanced Due Diligence (EDD) search logs action.",
        "properties": {
          "action": {
            "enum": [
              "show-edd-search-logs",
            ],
            "type": "string",
          },
          "searchLogId": {
            "$ref": "#/components/schemas/ResourceId",
          },
          "type": {
            "enum": [
              "arrest",
              "bankruptcy",
              "fraud",
              "occupation",
            ],
            "type": "string",
          },
        },
        "readOnly": true,
        "type": "object",
      },
      "StringCustomField": {
        "properties": {
          "_links": {
            "$ref": "#/components/schemas/SelfLink",
          },
          "additionalSchema": {
            "description": "Additional schema which adds additional values constrains.",
            "properties": {
              "allowedValues": {
                "description": "List of allowed values.",
                "items": {
                  "type": "string",
                },
                "type": "array",
              },
              "default": {
                "description": "Default value.",
                "type": "string",
              },
              "maxLength": {
                "description": "Maximum allowed string length .
A maximum length of 4000 characters can be configured.
By default, this value is set to 255.",
                "type": "integer",
              },
              "pattern": {
                "description": "Allowed regular expression of a string.",
                "example": "/^[0-9]+$/",
                "type": "string",
              },
              "required": {
                "description": "Specifies whether this value is required.",
                "type": "boolean",
              },
            },
            "type": [
              "object",
              "null",
            ],
          },
          "description": {
            "description": "Description of the custom field.",
            "type": [
              "string",
              "null",
            ],
          },
          "name": {
            "description": "Name of the custom field.",
            "readOnly": true,
            "type": "string",
          },
          "type": {
            "description": "Describes the data type. Custom field type value cannot be changed.

Regular string of up to 255 characters.",
            "enum": [
              "string",
            ],
            "type": "string",
          },
        },
        "required": [
          "type",
        ],
        "type": "object",
      },
      "Subscription": {
        "properties": {
          "_embedded": {
            "description": "Embedded objects that are requested by the \`expand\` query parameter.",
            "properties": {
              "customer": {
                "type": "object",
              },
              "initialInvoice": {
                "type": "object",
              },
              "leadSource": {
                "type": "object",
              },
              "paymentInstrument": {
                "type": "object",
              },
              "recentInvoice": {
                "type": "object",
              },
              "shippingRate": {
                "type": "object",
              },
              "upcomingInvoice": {
                "type": "object",
              },
              "website": {
                "type": "object",
              },
            },
            "readOnly": true,
            "type": "object",
          },
          "_links": {
            "description": "Related links.",
            "items": {
              "properties": {
                "href": {
                  "description": "Link URL.",
                  "type": "string",
                },
                "rel": {
                  "description": "Type of link.",
                  "enum": [
                    "self",
                    "website",
                    "customer",
                    "initialInvoice",
                    "recentInvoice",
                    "approvalUrl",
                    "attachments",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "abandonReminderNumber": {
            "description": "Number of abandon order reminder events that are triggered.",
            "readOnly": true,
            "type": [
              "integer",
              "null",
            ],
          },
          "abandonReminderTime": {
            "description": "Date and time when the abandon order reminder event triggers.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "abandonTime": {
            "description": "Date and time when the pending order is automatically abandoned.
If this value is not passed during order creation,
a [pending order TTL](https://www.rebilly.com/catalog/all/organizations/patchorganization/#!t=request&path=settings/billing/pendingOrderTtl) setting is used to calculate the value.",
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
          },
          "activationTime": {
            "description": "Date and time when the order is activated.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
            "x-sortable": true,
          },
          "autopay": {
            "default": true,
            "description": "Specifies if payment attempts are made automatically.
If autopay is enabled, the payment is retrieved from the customer on the renewal date using the payment instrument that is set at \`paymentInstrumentId\`,
or the default payment instrument on the subscription.",
            "type": "boolean",
          },
          "billingAddress": {
            "description": "Billing address of the order.",
            "oneOf": [
              {
                "$ref": "#/components/schemas/ContactObject",
              },
              {
                "type": "null",
              },
            ],
          },
          "billingPortalToken": {
            "description": "Customer JWT to access billing portal. This field is presented only if billing portal exists.
This is an experimental field and can be changed or removed in the future.",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
            "x-badges": [
              {
                "name": "Experimental",
              },
            ],
          },
          "billingStatus": {
            "description": "Billing status of the most recent invoice.
This value may help you to determine if you should change the service status of the service,
such as suspending the service.",
            "enum": [
              "draft",
              "unpaid",
              "past-due",
              "abandoned",
              "paid",
              "voided",
              "refunded",
              "disputed",
              "partially-refunded",
              "partially-paid",
            ],
            "readOnly": true,
            "type": "string",
          },
          "cancelCategory": {
            "description": "Category of the cancellation.",
            "enum": [
              "billing-failure",
              "did-not-use",
              "did-not-want",
              "missing-features",
              "bugs-or-problems",
              "do-not-remember",
              "risk-warning",
              "contract-expired",
              "too-expensive",
              "never-started",
              "switched-plan",
              "other",
              null,
            ],
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "cancelDescription": {
            "description": "Description of the cancellation reason in free form.",
            "maxLength": 255,
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "canceledBy": {
            "description": "Specifies who initiated the cancellation.",
            "enum": [
              "merchant",
              "customer",
              "rebilly",
              null,
            ],
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "churnTime": {
            "description": "Date and time when the subscription is deactivated.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
            "x-sortable": true,
          },
          "couponIds": {
            "description": "List of coupons to redeem on the customer and restrict to this order.

For more information, see [Coupons](https://www.rebilly.com/docs/settings/coupons-and-discounts/).

This parameter uses the following logic:

- If this parameter is not supplied, applied coupons are not changed.
- If an empty array is supplied, all applied coupon redemptions are canceled.
- If a list of coupons is supplied, unapplied coupons in the list are applied.
  Coupons that have already been applied do not change state.
  Applied coupons that are not supplied in list are canceled.

If the list of applied coupons on a pending order is changed by this parameter during an order update, the invoice for the order is reissued.",
            "items": {
              "description": "ID of the coupon.",
              "type": "string",
            },
            "type": [
              "array",
              "null",
            ],
            "writeOnly": true,
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "currency": {
            "$ref": "#/components/schemas/CurrencyCode",
            "description": "Currency of the order.",
            "readOnly": true,
          },
          "customFields": {
            "$ref": "#/components/schemas/ResourceCustomFields",
          },
          "customerId": {
            "$ref": "#/components/schemas/CustomerId",
          },
          "delinquencyPeriod": {
            "default": null,
            "description": "Length of time, in ISO-8601 durations format,
which is added to the due time of the order when setting the delinquency time for all related invoices.
When the delinquency time of an invoice is reached, the order is automatically canceled.

If the provided value is \`null\`, the order does not change state.",
            "example": "P7D",
            "type": [
              "string",
              "null",
            ],
          },
          "deliveryAddress": {
            "description": "Delivery address of the order.",
            "oneOf": [
              {
                "$ref": "#/components/schemas/ContactObject",
              },
              {
                "type": "null",
              },
            ],
          },
          "id": {
            "description": "ID of the order.",
            "example": "sub_01HRF27SATGE4Z6PBJE6PD8328",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "inTrial": {
            "description": "Specifies if the subscription is currently in a trial period.",
            "readOnly": true,
            "type": "boolean",
          },
          "initialInvoiceId": {
            "description": "ID of the initial invoice.",
            "example": "in_0YVF9605RKC62BP14NE2R7V2XT",
            "maxLength": 50,
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "invoiceTimeShift": {
            "description": "Shifts issue time and due time of invoices for this subscription.

This setting overrides plan settings.
To use plan settings, set this value to \`null\`.

To use multiple plans in one subscription,
all plans must have the same billing period,
this property enables the customer to subscribe to different plans.",
            "example": null,
            "oneOf": [
              {
                "$ref": "#/components/schemas/InvoiceTimeShift",
              },
              {
                "type": "null",
              },
            ],
          },
          "isTrialConverted": {
            "description": "Specifies if a subscription had trial conversion.
Trial conversion is when at least one successful payment is made on the subscription after a trial.",
            "example": true,
            "readOnly": true,
            "type": "boolean",
          },
          "isTrialOnly": {
            "default": false,
            "description": "Specifies if a subscription ends after a trial period.
If this value is \`true\`, recurring settings are ignored.",
            "type": "boolean",
          },
          "items": {
            "description": "Details of items in the order.",
            "items": {
              "$ref": "#/components/schemas/SubscriptionOrOneTimeSaleItem",
            },
            "minItems": 1,
            "type": "array",
          },
          "lineItemSubtotal": {
            "description": "Subtotal of line items in this subscription (signed value).
If credits exceed debits, this value is a negative number.",
            "properties": {
              "amount": {
                "description": "Amount of the subtotal.",
                "example": 49.95,
                "format": "double",
                "type": "number",
                "x-sortable": true,
                "x-type": "Money",
              },
              "currency": {
                "$ref": "#/components/schemas/CurrencyCode",
              },
            },
            "readOnly": true,
            "type": "object",
          },
          "lineItems": {
            "deprecated": true,
            "description": "Subscription line items which queue until the next renewal, or interim, invoice is issued for the subscription.",
            "items": {
              "deprecated": true,
              "description": "Invoice line item. Use the \`isInterim\` property of upcoming invoice items instead.",
              "properties": {
                "createdTime": {
                  "$ref": "#/components/schemas/CreatedTime",
                },
                "description": {
                  "description": "Description of the line item.",
                  "maxLength": 1000,
                  "type": "string",
                },
                "periodEndTime": {
                  "description": "Date and time when the service period ends for this item.",
                  "format": "date-time",
                  "type": "string",
                },
                "periodStartTime": {
                  "description": "Date and time when the service period begins for this item.",
                  "format": "date-time",
                  "type": "string",
                },
                "quantity": {
                  "description": "Quantity of the line item.",
                  "example": 1,
                  "type": "integer",
                },
                "type": {
                  "description": "Type of invoice line item.",
                  "enum": [
                    "debit",
                    "credit",
                  ],
                  "type": "string",
                },
                "unitPriceAmount": {
                  "description": "Unit price of the line item.",
                  "example": 49.95,
                  "format": "double",
                  "type": "number",
                },
                "unitPriceCurrency": {
                  "$ref": "#/components/schemas/CurrencyCode",
                },
                "updatedTime": {
                  "$ref": "#/components/schemas/UpdatedTime",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "notes": {
            "description": "Notes for the customer displayed on the order invoice.",
            "type": "string",
          },
          "orderId": {
            "description": "ID of the order (experimental).",
            "example": "ord_01GYJPRKHBD6ZYHH897QCJMBS4",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "orderType": {
            "description": "Specifies the type of order.
An order may be a subscription or a one-time purchase.",
            "enum": [
              "subscription-order",
            ],
            "type": "string",
            "x-basic": true,
          },
          "organizationId": {
            "allOf": [
              {
                "$ref": "#/components/schemas/OrganizationId",
              },
            ],
            "readOnly": true,
          },
          "paymentInstrumentId": {
            "description": "ID of the payment instrument to use for autopay.
If this value is not provided, or if the payment instrument is inactive,
the customer's default payment instrument is used.",
            "example": "inst_0YVB8KPKNXCBR9EDX7JHSED75N",
            "maxLength": 50,
            "type": [
              "string",
              "null",
            ],
          },
          "poNumber": {
            "description": "Purchase order number displayed on the issued invoices.",
            "example": "PO123456",
            "type": [
              "string",
              "null",
            ],
          },
          "rebillNumber": {
            "description": "Current billing period number.",
            "readOnly": true,
            "type": [
              "integer",
              "null",
            ],
            "x-sortable": true,
          },
          "recentInvoiceId": {
            "description": "ID of the most recently issued invoice.
The invoice might not be \`paid\` yet.",
            "example": "in_0YVF9605RKC62BP14NE2R7V2XT",
            "maxLength": 50,
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "recurringInterval": {
            "description": "Recurring interval to override plan settings.
To use plan settings, set this value to \`null\`.

To use multiple plans in one subscription,
all plans must have the same recurring period length.",
            "example": null,
            "properties": {
              "periodAnchorInstruction": {
                "$ref": "#/components/schemas/ServicePeriodAnchorInstruction",
              },
            },
            "type": [
              "object",
              "null",
            ],
          },
          "renewalReminderNumber": {
            "description": "Number of triggered renewal reminder events.",
            "readOnly": true,
            "type": [
              "integer",
              "null",
            ],
          },
          "renewalReminderTime": {
            "description": "Date and time when the renewal reminder event triggers.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "renewalTime": {
            "description": "Date and time when the subscription renews.",
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
            "x-basic": true,
            "x-sortable": true,
          },
          "revision": {
            "description": "Number of times the order data has been modified.

The revision is useful when analyzing webhook data to determine if the
change takes precedence over the current representation.",
            "readOnly": true,
            "type": "integer",
          },
          "riskMetadata": {
            "allOf": [
              {
                "$ref": "#/components/schemas/RiskMetadata",
              },
            ],
            "description": "Risk metadata.
If this value is \`null\`, this field uses risk metadata that is captured when creating the payment token.",
            "example": null,
            "type": [
              "object",
              "null",
            ],
          },
          "shipping": {
            "$ref": "#/components/schemas/Shipping",
          },
          "startTime": {
            "description": "Date and time when the subscription starts.
If this value is \`null\`, the current time is used.
This value cannot be more than one service period in the past.",
            "example": null,
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
            "x-basic": true,
            "x-sortable": true,
          },
          "status": {
            "description": "Status of the subscription service.
A subscription starts in the \`pending\` status, and becomes \`active\` when the service period begins.",
            "enum": [
              "pending",
              "active",
              "abandoned",
              "canceled",
              "churned",
              "paused",
              "voided",
              "completed",
              "trial-ended",
            ],
            "readOnly": true,
            "type": "string",
          },
          "trial": {
            "description": "Trial details.
To use plan defaults do not send the \`trial\` key, or send a \`null\` value.",
            "properties": {
              "enabled": {
                "description": "Specifies if there is a trial for this subscription.
Plans without trial prices are free trials.",
                "type": "boolean",
              },
              "endTime": {
                "description": "Time and date when the trial ends.
If a trial is enabled on this subscription, a value must be provided.",
                "format": "date-time",
                "type": [
                  "string",
                  "null",
                ],
              },
            },
            "type": "object",
          },
          "trialReminderNumber": {
            "description": "Number of triggered trial reminder events.",
            "readOnly": true,
            "type": [
              "integer",
              "null",
            ],
          },
          "trialReminderTime": {
            "description": "Date and time when the trial reminder event triggers.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
          "voidTime": {
            "description": "Date and time when the order is voided.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "websiteId": {
            "allOf": [
              {
                "$ref": "#/components/schemas/WebsiteId",
              },
            ],
            "x-basic": true,
            "x-sortable": true,
          },
        },
        "required": [
          "orderType",
          "customerId",
          "websiteId",
          "items",
        ],
        "type": "object",
      },
      "SubscriptionCancellation": {
        "properties": {
          "_links": {
            "$ref": "#/components/schemas/SelfLink",
          },
          "appliedInvoiceId": {
            "description": "ID of the invoice on which the cancellation fees or credits are applied.",
            "example": "in_0YVF9605RKC62BP14NE2R7V2XT",
            "maxLength": 50,
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "canceledBy": {
            "default": "customer",
            "description": "Specifies who initiated the cancellation.",
            "enum": [
              "merchant",
              "customer",
              "rebilly",
            ],
            "type": "string",
          },
          "canceledTime": {
            "description": "Date and time when a subscription is cancelled.
By default, this occurs when \`status\` is \`confirmed\`, unless \`draft\` is specified.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "churnTime": {
            "description": "Date and time when the subscription is deactivated.",
            "format": "date-time",
            "type": "string",
          },
          "churnTimePolicy": {
            "description": "Specifies when the subscription is to be deactivated.
The \`churnTimePolicy\` takes precedence over the \`churnTime\` in request.",
            "enum": [
              "null",
              "now",
              "at-next-renewal",
            ],
            "type": [
              "string",
              "null",
            ],
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "description": {
            "description": "Description of the cancellation reason in free form.",
            "maxLength": 255,
            "type": "string",
          },
          "id": {
            "description": "ID of the cancellation.",
            "example": "sub_cnl_0YVJ5XVQM9CDP8248ZQX0RDMKV",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "lineItemSubtotal": {
            "description": "Subtotal of the line items added after the subscription cancellation.",
            "properties": {
              "amount": {
                "description": "Subtotal amount of the line items.",
                "example": 49.95,
                "type": "number",
              },
              "currency": {
                "$ref": "#/components/schemas/CurrencyCode",
              },
            },
            "readOnly": true,
            "type": "object",
          },
          "lineItems": {
            "description": "Items to be added to the new invoice.
Proration item is generated and added automatically.",
            "items": {
              "description": "Invoice line item.",
              "properties": {
                "createdTime": {
                  "$ref": "#/components/schemas/CreatedTime",
                },
                "description": {
                  "description": "Description of the line item.",
                  "maxLength": 1000,
                  "type": "string",
                },
                "periodEndTime": {
                  "description": "Date and time when the period ends for this item.",
                  "format": "date-time",
                  "type": "string",
                },
                "periodStartTime": {
                  "description": "Date and time when the period begins for this item.",
                  "format": "date-time",
                  "type": "string",
                },
                "quantity": {
                  "description": "Quantity of the line item.",
                  "example": 1,
                  "type": "integer",
                },
                "type": {
                  "description": "Type of invoice line item.",
                  "enum": [
                    "debit",
                    "credit",
                  ],
                  "type": "string",
                },
                "unitPriceAmount": {
                  "description": "Unit price of the line item.",
                  "example": 49.95,
                  "format": "double",
                  "type": "number",
                },
                "unitPriceCurrency": {
                  "$ref": "#/components/schemas/CurrencyCode",
                },
                "updatedTime": {
                  "$ref": "#/components/schemas/UpdatedTime",
                },
              },
              "required": [
                "type",
                "unitPriceAmount",
                "unitPriceCurrency",
                "quantity",
              ],
              "type": "object",
            },
            "type": "array",
          },
          "prorated": {
            "default": false,
            "description": "Specifies if the customer gets a pro-rata credit for the time remaining between \`churnTime\` and subscription next renewal time.",
            "type": "boolean",
          },
          "proratedInvoiceId": {
            "description": "ID of the invoice on which the cancellation proration is calculated.",
            "example": "in_0YVF9605RKC62BP14NE2R7V2XT",
            "maxLength": 50,
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "reason": {
            "default": "other",
            "description": "Reason for the cancellation.",
            "enum": [
              "did-not-use",
              "did-not-want",
              "missing-features",
              "bugs-or-problems",
              "do-not-remember",
              "risk-warning",
              "contract-expired",
              "too-expensive",
              "other",
              "billing-failure",
            ],
            "type": "string",
          },
          "status": {
            "default": "confirmed",
            "description": "Status of the subscription order.",
            "enum": [
              "draft",
              "confirmed",
              "completed",
              "revoked",
            ],
            "type": "string",
            "x-enumDescriptions": {
              "completed": "Marks a subscription cancellation as completed.
This is a read-only status that is set when the \`churnTime\` is reached.
The cancellation may not be changed or deleted when the status is \`completed\`.",
              "confirmed": "Confirms a subscription cancellation.
Sets the subscription to cancel when the \`churnTime\` is reached.",
              "draft": "Creates a daft cancellation so that the cancellation and charge can be previewed.",
              "revoked": "Revokes a subscription cancellation.",
            },
          },
          "subscriptionId": {
            "description": "ID of the canceled subscription order.",
            "example": "sub_01HRF27SATGE4Z6PBJE6PD8328",
            "maxLength": 50,
            "type": "string",
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
        },
        "required": [
          "subscriptionId",
          "churnTimePolicy",
        ],
        "type": "object",
      },
      "SubscriptionChange": {
        "properties": {
          "effectiveTime": {
            "description": "Date from which the renewal time for \`reset\` operations and proration calculations are made.
If this field is omitted, this value defaults to the current time.",
            "format": "date-time",
            "type": "string",
          },
          "items": {
            "description": "Details of items in the order.",
            "items": {
              "description": "New set of items for the subscription.
To remove an item, include the items array and exclude the items you want to remove.",
              "properties": {
                "plan": {
                  "description": "Plan details.",
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/OriginalPlan",
                    },
                    {
                      "$ref": "#/components/schemas/FlexiblePlan",
                    },
                  ],
                },
                "quantity": {
                  "description": "Number of units of the product on the given plan.",
                  "type": "integer",
                },
                "usageLimits": {
                  "description": "Specifies the soft and hard usage limit thresholds for an item with a metered billing plan.
This value is ignored when the plan is not metered.",
                  "properties": {
                    "hardLimit": {
                      "description": "Defines a limit where the customer can no longer use the service.
Hard limits are used in addition to soft limits.
When a soft limit is reached,
a customer may receive a notification
but the service can still be provided up to the hard limit value so that the customer can upgrade their plan.
When the reported usage reaches the configured limit,
a specific event is triggered.
To notify the customer in the merchant system,
or block a service,
a webhook and notification can be configured for this event.
When the total usage reaches the hard limit quantity,
or amount values,
metered billing plan usages can no longer be reported.",
                      "maxProperties": 1,
                      "minProperties": 1,
                      "properties": {
                        "amount": {
                          "description": "Usage limit amount in the currency of the order.",
                          "format": "double",
                          "minimum": 0.01,
                          "type": "number",
                        },
                        "quantity": {
                          "description": "Usage limit quantity.",
                          "minimum": 1,
                          "type": "integer",
                        },
                      },
                      "type": "object",
                    },
                    "softLimit": {
                      "description": "Defines thresholds for notification purposes.
For example, to notify the customer that their usage is near the hard limit of their metered billing plan.
This notification informs the customer so that they can upgrade their plan before the hard limit is reached.
When the reported usage reaches 75%, 90%, and 100% of the configured limit a specific event is fired.
To notify the customer, a webhook and notification can be configured for this event.
This field is useful for accounting and customer success purposes.
The usage of metered billing plans can still be reported if the soft limit is reached.",
                      "maxProperties": 1,
                      "minProperties": 1,
                      "properties": {
                        "amount": {
                          "description": "Usage limit amount in the currency of the order.",
                          "format": "double",
                          "minimum": 0.01,
                          "type": "number",
                        },
                        "quantity": {
                          "description": "Usage limit quantity.",
                          "minimum": 1,
                          "type": "integer",
                        },
                      },
                      "type": "object",
                    },
                  },
                  "type": "object",
                },
              },
              "required": [
                "plan",
              ],
              "type": "object",
            },
            "minItems": 1,
            "type": "array",
          },
          "keepTrial": {
            "default": false,
            "description": "Specifies if the subscription order must retain its active trial.
This field is only applicable if \`renewalPolicy\` is set to \`retain\`.",
            "type": "boolean",
          },
          "preview": {
            "default": false,
            "description": "Specifies if changes to the subscription can be previewed.
Subscriptions cannot be changed in preview.",
            "type": "boolean",
          },
          "prorated": {
            "description": "Specifies whether to give a pro rata credit for the amount of time remaining between the \`effectiveTime\` and the end of the current period.

In addition, if the \`renewalTime\` is retained, by setting the \`renewalPolicy\` to \`retain\`,
a pro rata debit occurs for the amount between the \`effectiveTime\` and the \`renewalTime\` as a percentage of the normal period size.",
            "type": "boolean",
          },
          "renewalPolicy": {
            "description": "Specifies if the subscription retains its current \`renewalTime\` or resets it to a newly calculated \`renewalTime\`.",
            "enum": [
              "reset",
              "retain",
            ],
            "type": "string",
          },
        },
        "required": [
          "items",
          "renewalPolicy",
          "prorated",
        ],
        "type": "object",
      },
      "SubscriptionInvoice": {
