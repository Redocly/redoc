                  "format": "date",
                  "type": "string",
                },
                "name": {
                  "description": "Trade name.",
                  "example": "Rogers",
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
        },
        "type": "object",
      },
      "CreditMemo": {
        "description": "Credit memo object.",
        "properties": {
          "_links": {
            "description": "Related links.",
            "items": {
              "properties": {
                "href": {
                  "description": "Link URL.",
                  "type": "string",
                },
                "rel": {
                  "description": "Type of link.",
                  "enum": [
                    "self",
                    "customer",
                    "invoice",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "allocations": {
            "description": "Allocations reduce the unused amount of a credit memo.",
            "properties": {
              "invoices": {
                "description": "List of invoices that the credit memo is allocated to.

- To delete invoice allocations, send an empty invoice allocation array in the request.
  Only \`unpaid\`, \`partially-paid\`, and \`past-due\` invoices can be deleted.
- To modify invoice allocations, send a modified invoice allocation array in the request.
  Only \`unpaid\`, \`partially-paid\`, and \`past-due\` invoices can be modified.
- If you do not want to modify or delete invoice allocations, do not send an invoice allocation array in the request.",
                "items": {
                  "properties": {
                    "amount": {
                      "description": "Amount of credit that is allocated from the credit memo to the invoice.
If the \`amount\` value is not supplied or exceeds the unused amount of the credit memo or the invoice due amount, the lesser of the following two values is used:
- The unused amount of the credit memo.
- The invoice due amount.",
                      "format": "double",
                      "type": "number",
                    },
                    "createdTime": {
                      "$ref": "#/components/schemas/ServerTimestamp",
                      "description": "Date and time at which a credit memo is allocated.",
                    },
                    "currency": {
                      "$ref": "#/components/schemas/CurrencyCode",
                      "readOnly": true,
                    },
                    "invoiceId": {
                      "description": "ID of invoice to which the credit memo is allocated.",
                      "example": "in_0YVF9605RKC62BP14NE2R7V2XT",
                      "maxLength": 50,
                      "type": "string",
                    },
                    "updatedTime": {
                      "$ref": "#/components/schemas/UpdatedTime",
                    },
                  },
                  "type": "object",
                },
                "type": "array",
              },
              "transactions": {
                "description": "List of transactions (typically refunds, credits, and chargebacks) that are allocated to reduce the unused amount of a credit memo.

  - To delete transaction allocations, send an empty transaction allocation array in the request.
  - To modify transaction allocations, send a modified transaction allocation array in the request.
  - If you do not want to modify or delete transaction allocations, do not send a transaction allocation array in the request.",
                "items": {
                  "properties": {
                    "amount": {
                      "description": "Amount of credit that is allocated from the credit memo to the transaction.
If the \`amount\` value is not supplied or exceeds the unused amount of the credit memo or the transaction amount, the lesser of the following two values is used:
- The unused amount of the credit memo.
- The transaction amount.",
                      "format": "double",
                      "type": "number",
                    },
                    "createdTime": {
                      "$ref": "#/components/schemas/CreatedTime",
                    },
                    "currency": {
                      "$ref": "#/components/schemas/CurrencyCode",
                      "readOnly": true,
                    },
                    "transactionId": {
                      "$ref": "#/components/schemas/TransactionId",
                      "description": "ID of the transaction to which the credit memo is allocated.",
                    },
                    "updatedTime": {
                      "$ref": "#/components/schemas/UpdatedTime",
                    },
                  },
                  "type": "object",
                },
                "type": "array",
              },
            },
            "type": "object",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "currency": {
            "$ref": "#/components/schemas/CurrencyCode",
            "readOnly": true,
          },
          "customerId": {
            "$ref": "#/components/schemas/CustomerId",
            "readOnly": true,
          },
          "description": {
            "description": "Public description, that is visible to customers, which describes the purpose of the credit memo.",
            "type": "string",
            "x-basic": true,
          },
          "id": {
            "description": "ID of the credit memo.",
            "example": "crmm_0YVCNN22TWC3G8H82QNPNVZCHG",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "invoiceId": {
            "description": "ID of the invoice to which the credit memo is issued.",
            "example": "in_0YVF9605RKC62BP14NE2R7V2XT",
            "maxLength": 50,
            "type": [
              "string",
              "null",
            ],
          },
          "items": {
            "description": "Items of the credit memo.",
            "items": {
              "properties": {
                "description": {
                  "description": "Description of the credit memo item.",
                  "type": "string",
                },
                "id": {
                  "description": "ID of the credit memo item.",
                  "example": "crmm_itm_0YVCNN22TWC3G8H82QNPNVZCHG",
                  "maxLength": 50,
                  "readOnly": true,
                  "type": "string",
                },
                "invoiceItemId": {
                  "description": "ID of the invoice item to which the credit item is referenced.",
                  "example": "ii_0YVFDEQS2KCFTBN9HXWJFY55GV",
                  "maxLength": 50,
                  "type": [
                    "string",
                    "null",
                  ],
                },
                "planId": {
                  "description": "ID of the related plan.",
                  "example": "plan_0YV7DENSVGDBW9S71XZNNYYQ0X",
                  "maxLength": 50,
                  "type": [
                    "string",
                    "null",
                  ],
                },
                "price": {
                  "description": "Total price of the credit memo item.",
                  "format": "double",
                  "readOnly": true,
                  "type": "number",
                },
                "productId": {
                  "description": "ID of the related product.",
                  "example": "prod_0YV7DES3WPC5J8JD8QTVNZBZNZ",
                  "maxLength": 50,
                  "type": [
                    "string",
                    "null",
                  ],
                },
                "quantity": {
                  "description": "Quantity of the credit memo item.",
                  "type": "integer",
                },
                "tax": {
                  "description": "Credit memo item tax.",
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/CreditMemoTaxItem",
                    },
                    {
                      "type": "null",
                    },
                  ],
                },
                "unitPrice": {
                  "description": "Price of the credit memo item.",
                  "format": "double",
                  "type": "number",
                },
              },
              "required": [
                "unitPrice",
                "quantity",
              ],
              "type": "object",
            },
            "type": "array",
          },
          "number": {
            "description": "Auto-incrementing number based on the sequence of credit memos for any particular customer.",
            "readOnly": true,
            "type": "integer",
          },
          "reason": {
            "description": "Reason for the credit memo.",
            "enum": [
              "return",
              "product-unsatisfactory",
              "order-change",
              "order-cancellation",
              "chargeback",
              "write-off",
              "waiver",
              "customer-credit",
              "other",
            ],
            "type": "string",
          },
          "revision": {
            "description": "Number of times the credit memo has been modified.",
            "readOnly": true,
            "type": "integer",
          },
          "shippingAmount": {
            "default": 0,
            "description": "Shipping amount of an invoice to credit.",
            "format": "double",
            "type": "number",
            "x-type": "Money",
          },
          "status": {
            "description": "Status of the credit memo.",
            "enum": [
              "issued",
              "applied",
              "partially-applied",
              "voided",
            ],
            "readOnly": true,
            "type": "string",
            "x-enumDescriptions": {
              "applied": "The full amount of the credit memo has been applied. No more credit can be created from it.",
              "issued": "The credit memo is available with a full amount to be applied.",
              "partially-applied": "A partial amount of the credit memo has been applied.
A credit can be created from the remaining amount.",
              "voided": "Credit memo has been voided and cannot be used anymore.",
            },
          },
          "taxAmount": {
            "default": 0,
            "description": "Sum of items tax amount of an invoice to credit.",
            "format": "double",
            "readOnly": true,
            "type": "number",
            "x-type": "Money",
          },
          "totalAmount": {
            "default": 0,
            "description": "Total amount of all credits in the credit memo, including items, shipping, and tax.",
            "format": "double",
            "readOnly": true,
            "type": "number",
            "x-type": "Money",
          },
          "unusedAmount": {
            "default": 0,
            "description": "Unused credit memo amount that has not been allocated.",
            "format": "double",
            "readOnly": true,
            "type": "number",
            "x-type": "Money",
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
        },
        "required": [
          "customerId",
          "currency",
        ],
        "type": "object",
      },
