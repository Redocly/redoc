    "schemas": {
      "AML": {
        "properties": {
          "_links": {
            "$ref": "#/components/schemas/SelfLink",
          },
          "address": {
            "description": "Addresses associated with the individual or entity.",
            "items": {
              "properties": {
                "address": {
                  "description": "Street address line 1.",
                  "readOnly": true,
                  "type": [
                    "string",
                    "null",
                  ],
                },
                "address2": {
                  "description": "Street address line 2.",
                  "readOnly": true,
                  "type": [
                    "string",
                    "null",
                  ],
                },
                "birthplace": {
                  "default": false,
                  "description": "Individual's place of birth.",
                  "readOnly": true,
                  "type": "boolean",
                },
                "city": {
                  "description": "City.",
                  "readOnly": true,
                  "type": [
                    "string",
                    "null",
                  ],
                },
                "country": {
                  "description": "Country.",
                  "readOnly": true,
                  "type": [
                    "string",
                    "null",
                  ],
                },
                "region": {
                  "description": "State, province, or region.",
                  "readOnly": true,
                  "type": [
                    "string",
                    "null",
                  ],
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "aliases": {
            "description": "List of aliases, if any.",
            "items": {
              "properties": {
                "authenticity": {
                  "description": "Degree of confidence in the alias.",
                  "enum": [
                    "strong",
                    "weak",
                    "unknown",
                  ],
                  "readOnly": true,
                  "type": "string",
                },
                "firstName": {
                  "description": "First name of alias.",
                  "readOnly": true,
                  "type": "string",
                },
                "lastName": {
                  "description": "Last name of alias.",
                  "readOnly": true,
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "comments": {
            "description": "Additional information. This content varies per list.",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "confidence": {
            "description": "Degree of confidence in the source list information.",
            "enum": [
              "weak",
              "medium",
              "strong",
              "very-strong",
            ],
            "readOnly": true,
            "type": "string",
          },
          "dob": {
            "description": "One or more possible dates of birth.",
            "items": {
              "description": "Date of birth.",
              "example": "1706-01-17",
              "format": "date",
              "readOnly": true,
              "type": "string",
            },
            "readOnly": true,
            "type": "array",
          },
          "firstName": {
            "description": "First name of the individual, or name of entity.",
            "example": "Benjamin",
            "readOnly": true,
            "type": "string",
          },
          "gender": {
            "description": "If \`type\`=\`individual\`, this field describes the gender of the individual.",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "lastName": {
            "description": "Last name of the individual. Returns a \`null\` value for single-named entities.",
            "example": "Franklin",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "legalBasis": {
            "description": "List of references to legal documents, if they exist.",
            "items": {
              "type": "string",
            },
            "readOnly": true,
            "type": "array",
          },
          "nationality": {
            "description": "Nationality of the individual or entity.",
            "readOnly": true,
            "type": "string",
          },
          "passport": {
            "description": "Individual's passport information.",
            "items": {
              "properties": {
                "number": {
                  "description": "Passport number.",
                  "readOnly": true,
                  "type": "string",
                },
                "registrationDate": {
                  "description": "Passport registration date.",
                  "format": "date",
                  "readOnly": true,
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "regime": {
            "description": "Describes the government, administration, or political entity.",
            "example": "United States Government",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "source": {
            "description": "Describes which list the result is from.",
            "readOnly": true,
            "type": "string",
          },
          "sourceType": {
            "description": "Describes the categories of the individual or entity.",
            "example": [
              "sanctions",
              "enforcements",
            ],
            "items": {
              "enum": [
                "pep",
                "sanctions",
                "adverse-media",
                "enforcements",
                "state-owned-enterprise",
              ],
              "type": "string",
            },
            "readOnly": true,
            "type": "array",
          },
          "title": {
            "description": "Individual's job title.",
            "example": [
              "Postmaster General",
              "Ambassador to France",
              "Ambassador to Sweden",
              "Supreme Executive Council of Commonwealth of Pennsylvania",
            ],
            "items": {
              "type": "string",
            },
            "readOnly": true,
            "type": [
              "array",
              "null",
            ],
          },
          "type": {
            "description": "Describes whether the source is an individual or an entity.",
            "enum": [
              "individual",
              "entity",
            ],
            "readOnly": true,
            "type": "string",
          },
        },
        "type": "object",
      },
