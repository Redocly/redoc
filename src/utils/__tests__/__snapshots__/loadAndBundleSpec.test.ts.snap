            },
            "readOnly": true,
            "type": "object",
          },
          "_links": {
            "description": "Related links.",
            "items": {
              "properties": {
                "href": {
                  "description": "Link URL.",
                  "type": "string",
                },
                "rel": {
                  "description": "Type of link.",
                  "enum": [
                    "self",
                    "customer",
                    "paymentInstrument",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "customerId": {
            "$ref": "#/components/schemas/CustomerId",
          },
          "documentMatches": {
            "description": "Proof of purchase document matches.",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/PurchaseMatches",
              },
            },
            "readOnly": true,
            "type": [
              "object",
              "null",
            ],
          },
          "documentSubtype": {
            "$ref": "#/components/schemas/KycDocumentSubtypes",
            "description": "Document subtype submitted for validation.",
          },
          "documentType": {
            "$ref": "#/components/schemas/KycDocumentTypes",
            "description": "Document type submitted for validation.
Only the \`identity-proof\` and \`address-proof\` types are analyzed automatically.",
          },
          "fileIds": {
            "description": "IDs of linked file objects.

Uploaded \`identity-proof\` files must have the following tags attached to be used for KYC purposes:
\`['kyc', 'id-front']\`, \`['kyc', 'id-back']\`, \`['kyc', 'face-proof']\`.",
            "items": {
              "example": "file_0YV7HZ7KDCC5WBV9Q7WRKG1H6N",
              "maxLength": 50,
              "type": "string",
            },
            "type": "array",
          },
          "id": {
            "description": "ID of the KYC document.",
            "example": "kyc_doc_0YV7JHY705C6DA487BFTAA33V8",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "matchLevel": {
            "description": "Tolerance level setting for document matches.",
            "example": 2,
            "maximum": 2,
            "minimum": 1,
            "type": "integer",
          },
          "notes": {
            "description": "Reviewer notes.",
            "type": [
              "string",
              "null",
            ],
          },
          "parsedData": {
            "description": "Parsed data.",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/PurchaseMatches",
              },
            },
            "readOnly": true,
            "type": [
              "object",
              "null",
            ],
          },
          "processedTime": {
            "description": "Date and time when the KYC document is processed.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "reason": {
            "description": "Reason for uploading.",
            "type": [
              "string",
              "null",
            ],
          },
          "rejectionReason": {
            "$ref": "#/components/schemas/KycDocumentRejection",
          },
          "requestId": {
            "description": "ID of the KYC request.",
            "example": "4f6cf35x-2c4y-483z-a0a9-158621f77a21",
            "maxLength": 50,
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "reviewStartTime": {
            "description": "Date and time when the manual review starts.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "reviewTime": {
            "description": "Date and time of manual review.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "reviewerId": {
            "description": "ID of the KYC document reviewer.",
            "example": "44433322-2c4y-483z-a0a9-158621f77a21",
            "maxLength": 50,
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "reviewerName": {
            "description": "First and last name of the KYC document reviewer.",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "revision": {
            "description": "Number of times the KYC document data has been modified.

Use this value when analyzing webhook data to determine if a change must take precedence over the current representation.",
            "readOnly": true,
            "type": "integer",
          },
          "settings": {
            "description": "Settings used to score the document.",
            "type": [
              "object",
              "null",
            ],
          },
          "status": {
            "description": "Status of the validation.",
            "enum": [
              "pending",
              "in-progress",
              "accepted",
              "rejected",
              "archived",
            ],
            "readOnly": true,
            "type": "string",
            "x-enumDescriptions": {
              "accepted": "Accepted by AI or a human.",
              "archived": "Archived by the Rebilly AI.",
              "in-progress": "Being analyzed by the Rebilly AI.",
              "pending": "Waiting to be reviewed or analyzed.",
              "rejected": "Rejected by AI or a human.",
            },
          },
          "tags": {
            "description": "List of KYC document tags.",
            "items": {
              "$ref": "#/components/schemas/Tag",
            },
            "readOnly": true,
            "type": "array",
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
        },
        "required": [
          "customerId",
          "documentType",
          "status",
          "fileIds",
        ],
        "title": "KYC documents.",
        "type": "object",
      },
      "PurchaseBumpOffer": {
        "description": "Purchase bump offer.",
        "properties": {
          "bumpAmount": {
