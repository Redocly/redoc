      "PayoutRequest": {
        "properties": {
          "_links": {
            "description": "Related links.",
            "items": {
              "properties": {
                "href": {
                  "description": "Link URL.",
                  "type": "string",
                },
                "rel": {
                  "description": "Type of link.",
                  "enum": [
                    "self",
                    "paymentInstrument",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "allocations": {
            "description": "List of credit transactions that are allocated to reduce the available amount of a payout request.",
            "items": {
              "properties": {
                "amount": {
                  "description": "Payout amount that is allocated from the payout request to the credit transaction.",
                  "format": "double",
                  "type": "number",
                },
                "createdTime": {
                  "$ref": "#/components/schemas/ServerTimestamp",
                  "description": "Date and time when a payout request is allocated.",
                },
                "gatewayName": {
                  "$ref": "#/components/schemas/GatewayName",
                  "description": "Name of the payment gateway that processed, or is selected to process, the transaction.",
                  "x-basic": true,
                  "x-label": "Gateway account",
                },
                "method": {
                  "$ref": "#/components/schemas/PaymentMethod",
                },
                "paymentInstrumentId": {
                  "description": "ID of the selected payment instrument for the transaction.",
                  "example": "inst_0YVB8KPKNXCBR9EDX7JHSED75N",
                  "maxLength": 50,
                  "type": "string",
                },
                "transactionId": {
                  "$ref": "#/components/schemas/TransactionId",
                  "description": "ID of the transaction to which the payout request is allocated.",
                },
                "transactionResult": {
                  "description": "Result of a transaction.",
                  "enum": [
                    "abandoned",
                    "approved",
                    "canceled",
                    "declined",
                    "unknown",
                  ],
                  "readOnly": true,
                  "type": "string",
                  "x-basic": true,
                },
                "updatedTime": {
                  "$ref": "#/components/schemas/UpdatedTime",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "amount": {
            "description": "Amount of the payout.",
            "format": "double",
            "type": "number",
            "x-type": "Money",
          },
          "availableAmount": {
            "description": "Available payout request amount that has not been allocated.",
            "format": "double",
            "readOnly": true,
            "type": "number",
            "x-type": "Money",
          },
          "cancellationReason": {
            "$ref": "#/components/schemas/PayoutRequestCancellation",
          },
          "createdTime": {
            "$ref": "#/components/schemas/ServerTimestamp",
            "description": "Date and time when the payout request is created.",
          },
          "currency": {
            "$ref": "#/components/schemas/CurrencyCode",
            "description": "Currency of the payout.",
          },
          "customerId": {
            "$ref": "#/components/schemas/CustomerId",
            "description": "ID of the customer who is requesting a payout.",
          },
          "description": {
            "description": "Description of payout request.",
            "type": [
              "string",
              "null",
            ],
          },
          "id": {
            "description": "Unique resource ID.",
            "example": "pout_req_0YVDMDE2BMC6KBB5MX76RF6T80",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "paymentInstrumentId": {
            "description": "ID of the requested payment instrument to offer for the payout.",
            "example": "inst_0YVB8KPKNXCBR9EDX7JHSED75N",
            "maxLength": 50,
            "type": [
              "string",
              "null",
            ],
          },
          "selectPaymentInstrumentUrl": {
            "description": "URL for the customer to select a preferred payment instrument.",
            "format": "uri",
            "readOnly": true,
            "type": "string",
          },
          "selectedPaymentInstrumentRedirectUrl": {
            "description": "URL where the customer is redirected when a payment instrument is selected. The default value is the website URL.
Use \`{{id}}\` as a placeholder for the payout request ID.",
            "example": "https://example.com/payout-request-success?id={{id}}",
            "format": "uri",
            "type": "string",
          },
          "status": {
            "description": "Status of the request.",
            "enum": [
              "pending",
              "instrument-selected",
              "partially-fulfilled",
              "fulfilled",
              "canceled",
            ],
            "readOnly": true,
            "type": "string",
            "x-enumDescriptions": {
              "canceled": "Request is canceled by merchant or customer.",
              "fulfilled": "Request is fully paid out when \`availableAmount\` reaches zero.",
              "instrument-selected": "Request has a selected payment instrument and is awaiting fulfillment.",
              "partially-fulfilled": "Request is partially paid out when \`availableAmount\` is less than \`amount\`.",
              "pending": "Request is awaiting customer's selection of the payment instrument or fulfillment.",
            },
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
            "description": "Date and time when the payout request is updated.",
          },
          "websiteId": {
            "$ref": "#/components/schemas/WebsiteId",
          },
        },
        "required": [
          "websiteId",
          "customerId",
          "currency",
          "amount",
        ],
        "type": "object",
      },
      "PayoutRequestCancellation": {
        "description": "Reason the payout request is canceled.",
        "properties": {
          "canceledBy": {
            "default": "customer",
            "description": "Specifies who initiated the cancellation.",
            "enum": [
              "merchant",
              "customer",
            ],
            "type": "string",
          },
          "description": {
            "description": "Description of the cancellation reason in free form.",
            "maxLength": 255,
            "type": "string",
          },
        },
        "readOnly": true,
        "type": [
          "object",
          "null",
        ],
      },
      "PercentageFeeFormula": {
        "properties": {
          "bips": {
            "$ref": "#/components/schemas/Bips",
          },
          "currency": {
            "$ref": "#/components/schemas/CurrencyCode",
          },
          "minAmount": {
            "description": "Minimum fee amount.
This value is applied when the calculated fee is less than the required minimum.",
            "example": 10,
            "format": "double",
            "type": "number",
            "x-type": "Money",
          },
          "type": {
            "description": "Type of fee.",
            "enum": [
              "percentage",
            ],
            "type": "string",
          },
        },
        "required": [
          "type",
          "currency",
          "bips",
        ],
        "type": "object",
      },
      "PeriodAnchor": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/SchedulingMethodDayOfMonth",
          },
          {
            "$ref": "#/components/schemas/SchedulingMethodDayOfWeek",
          },
        ],
        "description": "Instruction for calculating the period anchor.",
        "discriminator": {
          "mapping": {
            "day-of-month": "#/components/schemas/SchedulingMethodDayOfMonth",
            "day-of-week": "#/components/schemas/SchedulingMethodDayOfWeek",
          },
          "propertyName": "method",
        },
        "type": "object",
      },
      "PlaidAccountToken": {
        "properties": {
          "_links": {
            "$ref": "#/components/schemas/SelfLink",
          },
          "billingAddress": {
            "$ref": "#/components/schemas/ContactObject",
            "description": "Billing address object.",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "expirationTime": {
            "description": "Date and time when the token expired.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "id": {
            "$ref": "#/components/schemas/ResourceId",
            "description": "ID of the token.",
            "readOnly": true,
          },
          "isUsed": {
            "default": false,
            "description": "Specifies if the token is already used.",
            "readOnly": true,
            "type": "boolean",
          },
          "leadSource": {
            "allOf": [
              {
                "$ref": "#/components/schemas/LeadSource",
              },
            ],
            "writeOnly": true,
          },
          "method": {
            "description": "Payment method of the token.",
            "enum": [
              "plaid-account",
            ],
            "type": "string",
          },
          "paymentInstrument": {
            "description": "Plaid payment instrument details.",
            "properties": {
              "accountId": {
                "description": "ID of the Plaid account.",
                "type": "string",
              },
              "linkToken": {
                "description": "Plaid link token.",
                "type": "string",
                "writeOnly": true,
              },
              "publicToken": {
                "description": "Plaid public token.",
                "type": "string",
              },
            },
            "required": [
              "linkToken",
              "publicToken",
              "accountId",
            ],
            "type": "object",
          },
          "riskMetadata": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/RiskMetadata",
