          "type": {
            "description": "Type of fee.",
            "enum": [
              "fixed-fee",
            ],
            "type": "string",
          },
        },
        "required": [
          "type",
          "currency",
          "amount",
        ],
        "type": "object",
      },
      "FlexiblePlan": {
        "allOf": [
          {
            "properties": {
              "id": {
                "description": "ID of the plan.",
                "example": "plan_0YV7DENSVGDBW9S71XZNNYYQ0X",
