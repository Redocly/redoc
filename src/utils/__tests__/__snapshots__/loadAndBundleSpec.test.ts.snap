        ],
      },
      "KycDocumentRejectionReasonTypes": {
        "description": "Reason the document is rejected.",
        "enum": [
          "document-unreadable",
          "document-expired",
          "document-not-matching",
          "document-duplicate",
          "document-invalid",
          "document-not-open",
          "underage-person",
          "third-party-or-mismatch",
          "expiration-date-missing",
          "issue-date-missing",
          "dob-mismatch",
          "name-mismatch",
          "critical-info-missing",
          "old-address-on-id",
          "tampered-document",
          "other",
        ],
        "type": "string",
      },
      "KycDocumentSubtypes": {
        "enum": [
          "passport",
          "id-card",
          "driver-license",
          "birth-certificate",
          "utility-bill",
          "rental-receipt",
          "lease-agreement",
          "copy-credit-card",
          "credit-card-statement",
          "bank-statement",
          "inheritance-documentation",
          "tax-return",
          "salary-slip",
          "sale-of-assets",
          "public-health-card",
          "proof-of-age-card",
          "reverse-of-id",
          "public-service",
          "ewallet-holder-details",
          "ewallet-transaction-statement",
          "marriage-certificate",
          "firearms-license",
          "insurance-letter",
          "income-statement",
          "debtors-letter",
          "other",
          null,
        ],
        "type": [
          "string",
          "null",
        ],
      },
      "KycDocumentTypes": {
        "enum": [
          "identity-proof",
          "address-proof",
          "funds-proof",
          "purchase-proof",
          "credit-file-proof",
        ],
        "type": "string",
      },
      "KycIdentityMatches": {
        "description": "Matched identity data.",
        "properties": {
          "containsImage": {
            "description": "Specifies if the document includes an image that contains a face.",
            "example": true,
            "type": "boolean",
          },
          "dateOfBirth": {
            "description": "Date of birth detected on the document.
This value is null if no match is detected.",
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
          },
          "documentNumber": {
            "description": "Unique number on the identity document.
This value may contain alphanumeric characters.",
            "example": "1234567890",
            "type": [
              "string",
              "null",
            ],
          },
          "documentSubtype": {
            "$ref": "#/components/schemas/KycDocumentSubtypes",
            "description": "Interpreted subtype of the uploaded document.",
            "type": [
              "string",
              "null",
            ],
          },
          "expirationDate": {
            "description": "Expiration date detected on the document.
This value is null if no expiration date is detected.",
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
          },
          "expiryDate": {
            "deprecated": true,
            "description": "Use \`expirationDate\` field instead.",
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
          },
          "firstName": {
            "description": "First name of the customer.
This value is null if no match is found.",
            "example": "John",
            "type": [
              "string",
              "null",
            ],
          },
          "hasMatchingFaceProof": {
            "description": "Specifies if an identity document has matching face proof.",
            "example": false,
            "type": "boolean",
          },
          "hasMinimalAge": {
            "description": "Specifies that the individual is older than the minimal age limit.
The minimal age is 21+ the for USA and 18+ for all other countries.
This value is null if \`dateOfBirth\` is not determined.",
            "example": true,
            "readOnly": true,
            "type": [
              "boolean",
              "null",
            ],
          },
          "isIdentityDocument": {
            "description": "Specifies if the document resembles an ID.",
            "example": true,
            "type": "boolean",
          },
          "isPublishedOnline": {
            "description": "Specifies if an exact match of the document has been found online.",
            "example": false,
            "type": "boolean",
          },
          "isTampered": {
            "description": "Specifies if an identity document has been tampered with.",
            "example": false,
            "type": "boolean",
          },
          "issuanceCountry": {
            "description": "Country that issued the document.",
            "example": "CA",
            "maxLength": 2,
            "minLength": 2,
            "type": [
              "string",
              "null",
            ],
          },
          "issuanceRegion": {
            "description": "Region, state, province, or territory that issued the document.",
            "example": "Ontario",
            "type": [
              "string",
              "null",
            ],
          },
          "issueDate": {
            "description": "Issue date detected on the document.
This value is null if no issue date is detected.",
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
          },
          "lastName": {
            "description": "Last name of the customer.
This value is null if no match is found.",
            "example": "Doe",
            "type": [
              "string",
              "null",
            ],
          },
          "matchingImages": {
            "description": "URLs where matching images have been found online.",
            "items": {
              "type": "string",
            },
            "maxItems": 3,
            "readOnly": true,
            "type": "array",
          },
          "nationality": {
            "description": "Nationality detected on a passport or citizenship document.
This value is null if no nationality is detected.",
            "example": "US",
            "maxLength": 3,
            "type": [
              "string",
              "null",
            ],
          },
        },
        "type": "object",
      },
      "KycRequest": {
        "description": "KYC request information.",
        "properties": {
          "_embedded": {
            "description": "Embedded objects that are requested by the \`expand\` query parameter.",
            "properties": {
              "documents": {
                "type": "array",
              },
            },
            "readOnly": true,
            "type": "object",
          },
          "_links": {
            "description": "Related links.",
            "items": {
              "properties": {
                "href": {
                  "description": "Link URL.",
                  "type": "string",
                },
                "rel": {
                  "description": "Type of link.",
                  "enum": [
                    "self",
                    "documents",
                    "gatherer",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "createdTime": {
            "$ref": "#/components/schemas/CreatedTime",
          },
          "customerId": {
            "$ref": "#/components/schemas/CustomerId",
          },
          "documents": {
            "description": "Documents to request from the customer.",
            "items": {
              "$ref": "#/components/schemas/KycRequestDocument",
            },
            "minItems": 1,
            "type": "array",
          },
          "expirationTime": {
            "description": "Date and time when the request expires.
The default value is one hour in the future.",
            "format": "date-time",
            "type": "string",
          },
          "id": {
            "description": "ID of the KYC request.",
            "example": "kyc_req_0YV7JMJ3DBCGRBR7K9D4HVGPP5",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "matchLevel": {
            "default": 2,
            "description": "Tolerance level setting for document matches.
The value of \`1\` is more tolerant and \`2\` is strict.",
            "maximum": 2,
            "minimum": 1,
            "type": "integer",
          },
          "reason": {
            "description": "Reason for uploading.",
            "example": "spend limit",
            "type": [
              "string",
              "null",
            ],
          },
          "redirectUrl": {
            "description": "URL where the customer is redirected when a KYC document upload is complete.
When the customer is redirected,
Rebilly appends an \`info\` query parameter that has one of the following values:
  - \`back\`: Customer clicked the \`back to website\` link.
  - \`token_expired\`: Customer's token expired.
  - \`success\`: Customer uploaded KYC documents that have been analyzed.
  - \`manual\`: Customer uploaded KYC documents that require a manual review.
    This is because the analyzer rejected the documents or could not process them.
  - \`partial\`: Some of the customer's KYC documents have been analyzed,
    but other documents have not.
    For example, this may occur when a proof of address document is analyzed but proof of ID is not.

Example: \`https://example.com?info=success\`.",
            "format": "uri",
            "type": [
              "string",
              "null",
            ],
          },
          "revision": {
            "description": "Number of times the KYC request data has been modified.

Use this value when analyzing webhook data to determine if a change must take precedence over the current representation.",
            "readOnly": true,
            "type": "integer",
          },
          "status": {
            "description": "Status of the request.",
            "enum": [
              "gathering",
              "attempted",
              "partial",
              "pending-review",
              "fulfilled",
              "failed",
              "abandoned",
              "expired",
            ],
            "readOnly": true,
            "type": "string",
            "x-enumDescriptions": {
              "abandoned": "One or more documents provided but the request expired.
This is a permanent state.",
              "attempted": "At least one document has been provided but none were assigned the \`accepted\` status.
This is a temporary state.",
              "expired": "No documents were provided and the request expired.
This is a permanent state.",
              "failed": "At least one requested document has exhausted all attempts,
and has not been assigned a \`accepted\`, \`pending\`, or \`in-progress\` status.
This is a permanent state.",
              "fulfilled": "All requested documents are provided and have been assigned the \`accepted\` status.
This is a permanent state.",
              "gathering": "No documents have been provided yet.
This is a temporary state.",
              "partial": "At least one requested document has the \`accepted\` status,
but not all requested documents have been assigned the \`accepted\` status.
This is a temporary state.",
              "pending-review": "At least one requested document has the \`pending\` status,
and no requested documents have been assigned the \`accepted\` status.
This is a temporary state, until the document is reviewed,
or another \`accepted\` document is provided.",
            },
          },
          "updatedTime": {
            "$ref": "#/components/schemas/UpdatedTime",
          },
        },
        "required": [
          "customerId",
          "documents",
        ],
        "type": "object",
      },
      "KycRequestDocument": {
        "properties": {
          "faceLivenessRequired": {
            "description": "Specifies if the customer must use the face liveness feature when uploading a selfie.
For more information, see [Facial recognition and identity verification](https://www.rebilly.com/docs/kyc-and-aml/kyc-and-aml/#facial-recognition-identity-verification).",
            "type": "boolean",
          },
          "faceProofRequired": {
            "description": "Specifies if the customer must upload a photo of their face (selfie) that matches a provided KYC document.",
            "type": "boolean",
          },
          "maxAttempts": {
            "default": 3,
            "description": "Total number of allowed document upload attempts.
Use \`0\` to allow unlimited upload attempts.",
            "maximum": 100,
            "minimum": 0,
            "type": "integer",
          },
          "subtypes": {
            "description": "Permitted document subtype.",
            "items": {
              "$ref": "#/components/schemas/KycDocumentSubtypes",
            },
            "type": [
              "array",
              "null",
            ],
          },
          "type": {
            "$ref": "#/components/schemas/KycDocumentTypes",
            "description": "Type of document to request from the customer.",
          },
        },
        "required": [
          "type",
        ],
        "type": "object",
      },
      "KycSettings": {
        "description": "Settings for KYC score calculation.",
        "properties": {
          "addressProof": {
            "$ref": "#/components/schemas/KycSettingsAddress",
          },
          "identityProof": {
            "$ref": "#/components/schemas/KycSettingsIdentity",
          },
        },
        "type": "object",
      },
      "KycSettingsAddress": {
        "description": "Address proof settings.",
        "properties": {
          "thresholds": {
            "description": "Pass and fail threshold definition for the document verification process.",
            "properties": {
              "acceptAbove": {
                "description": "Overall score by which an identity proof document passes the verification process.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "rejectBelow": {
                "description": "Overall score by which an identity proof document fails the verification process.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
            },
            "type": "object",
          },
          "weights": {
            "description": "Property weights that are used for the KYC document verification process.

All KYC documents start the verification process with a score of 100.
If a check fails, the score is reduced by the corresponding weight.
For example, if the \`firstName\` check weight is set to \`5\`, and the check fails,
the KYC document score becomes \`95\`.",
            "properties": {
              "city": {
                "description": "Weight added if the customer's city is not matched.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "date": {
                "description": "Weight added if a date is not detected on the document.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "documentSubtype": {
                "description": "Weight added if the document is not one of the recognized document subtypes.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "firstName": {
                "description": "Weight added if the customer's first name is not matched.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "isTampered": {
                "description": "Weight added if the document has been tampered with.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "lastName": {
                "description": "Weight added if the customer's last name is not matched.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "line1": {
                "description": "Weight added if the customer's address is not matched.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "phone": {
                "description": "Weight added if a phone number is not detected on the document.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "postalCode": {
                "description": "Weight added if the customer's postal code is not matched.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "region": {
                "description": "Weight added if the customer's region is not matched.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
            },
            "type": "object",
          },
        },
        "type": "object",
      },
      "KycSettingsIdentity": {
        "description": "Identity proof settings.",
        "properties": {
          "thresholds": {
            "description": "Pass and fail threshold definition for the document verification process.",
            "properties": {
              "acceptAbove": {
                "description": "Overall score by which an identity proof document passes the verification process.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "rejectBelow": {
                "description": "Overall score by which an identity proof document fails the verification process.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
            },
            "type": "object",
          },
          "weights": {
            "description": "Property weights that are used for the KYC document verification process.

All KYC documents start the verification process with a score of 100.
If a check fails, the score is reduced by the corresponding weight.
For example, if the \`firstName\` check weight is set to \`5\`, and the check fails,
the KYC document score becomes \`95\`.",
            "properties": {
              "containsImage": {
                "description": "Weight added if the document does not include an image that contains a face.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "dateOfBirth": {
                "description": "Weight added if a date of birth is not detected on the document.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "documentSubtype": {
                "description": "Weight added if the document is not one of the recognized document subtypes.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "expirationDate": {
                "description": "Weight added if an expiration date is not detected on the document.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "firstName": {
                "description": "Weight added if the customer's first name is not matched.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "hasMatchingFaceProof": {
                "description": "Weight added if an identity document does not have matching face proof.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "hasMinimalAge": {
                "description": "Weight added if the document does not verify the minimal age limit.
Minimal age is 21+ the for USA and 18+ for all other countries.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "isIdentityDocument": {
                "description": "Weight added if the document does not resemble an ID.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "isPublishedOnline": {
                "description": "Weight added if an exact match of the document is not found online.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "isTampered": {
                "description": "Weight added if the document has been tampered with.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "issueDate": {
                "description": "Weight added if an issue date is not detected on the document.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "lastName": {
                "description": "Weight added if the customer's last name is not matched.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "matchesDateOfBirth": {
                "description": "Weight added if an identity document does not have a matching date of birth.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
              "nationality": {
                "description": "Weight added if a nationality is not detected on the document.",
                "maximum": 100,
                "minimum": 0,
                "type": "integer",
              },
            },
            "type": "object",
          },
        },
        "type": "object",
      },
