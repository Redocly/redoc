          {
            "label": "PHP-SDK-2.0",
            "lang": "PHP",
            "source": "$planForm = new Rebilly\\Entities\\Plan();
$planForm->setName('TestPlan');
$planForm->setCurrency('USD');
$planForm->setTrialAmount(1);
$planForm->setTrialPeriodUnit('day');
$planForm->setTrialPeriodLength(1);

