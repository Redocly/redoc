      "Quote": {
        "discriminator": {
          "mapping": {
            "change": "#/components/schemas/QuoteChangeOrder",
            "create": "#/components/schemas/QuoteCreateOrder",
            "reactivate": "#/components/schemas/QuoteReactivateOrder",
            "trial-only-conversion": "#/components/schemas/QuoteTrialConversionOrder",
          },
          "propertyName": "action",
        },
        "oneOf": [
          {
            "$ref": "#/components/schemas/QuoteCreateOrder",
          },
          {
            "$ref": "#/components/schemas/QuoteChangeOrder",
          },
          {
            "$ref": "#/components/schemas/QuoteReactivateOrder",
          },
          {
            "$ref": "#/components/schemas/QuoteTrialConversionOrder",
          },
        ],
      },
      "QuoteChangeOrder": {
        "properties": {
          "_embedded": {
            "description": "Embedded objects that are requested by the \`expand\` query parameter.",
            "properties": {
              "customer": {
                "type": "object",
              },
              "invoice": {
                "type": "object",
              },
              "subscription": {
                "type": "object",
              },
              "website": {
                "type": "object",
              },
            },
            "readOnly": true,
            "type": "object",
          },
          "_links": {
            "description": "Related links.",
            "items": {
              "properties": {
                "href": {
                  "description": "Link URL.",
                  "type": "string",
                },
                "rel": {
                  "description": "Type of link.
If the quote is issued, a customer can be redirected to the \`invoicePaymentFormUrl\` value
to pay the related invoice using one of the methods which are available to the customer.",
                  "enum": [
                    "self",
                    "quoteAcceptanceFormUrl",
                    "invoicePaymentFormUrl",
                  ],
                  "type": "string",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "acceptanceConditions": {
            "default": [
              "customer",
            ],
            "description": "Conditions that must be met for the quote to be automatically accepted.",
            "example": [
              "payment",
            ],
            "items": {
              "enum": [
                "customer",
                "payment",
              ],
              "type": "string",
              "x-enumDescriptions": {
                "customer": "Quote can be accepted by customer.",
                "payment": "Related invoice must be paid in full.",
              },
            },
            "type": "array",
            "writeOnly": true,
          },
          "acceptanceFulfillment": {
            "description": "List of \`acceptanceConditions\` with fulfillment status.",
            "items": {
              "properties": {
                "condition": {
                  "enum": [
                    "customer",
                    "payment",
                    "organization",
                  ],
                  "type": "string",
                },
                "isFulfilled": {
                  "type": "boolean",
                },
              },
              "type": "object",
            },
            "readOnly": true,
            "type": "array",
          },
          "acceptedTime": {
            "description": "Date and time when the quote is accepted.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "action": {
            "description": "Action of the quote for change order items.
When a quote is accepted, quote items are applied to the related order.",
            "enum": [
              "change",
            ],
            "example": "change",
            "type": "string",
          },
          "autopay": {
            "description": "Specifies if payment attempts for the related subscription are made automatically.
If autopay is enabled, the payment is retrieved from the customer on the renewal date using the payment instrument that is set at \`paymentInstrumentId\`,
or the default payment instrument on the subscription.",
            "type": [
              "boolean",
              "null",
            ],
          },
          "canceledTime": {
            "description": "Date and time when the quote is canceled.",
            "format": "date-time",
            "readOnly": true,
            "type": [
              "string",
              "null",
            ],
          },
          "couponIds": {
            "description": "List of coupons to redeem on the customer and apply to the related invoice.

For more information, see [Coupons](https://www.rebilly.com/docs/settings/coupons-and-discounts/).",
            "items": {
              "description": "Coupon ID.",
              "type": "string",
            },
            "type": [
              "array",
              "null",
            ],
          },
          "customerId": {
            "$ref": "#/components/schemas/CustomerId",
          },
          "effectiveTime": {
            "description": "Date from which the renewal time for \`reset\` operations and proration calculations are made.
If this field is omitted, this value defaults to the time of quote acceptance.",
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
          },
          "expirationTime": {
            "description": "Date and time when the quote expires.
The default expiration time is one month from the time the quote is issued.
In a \`draft\` state, this field may be \`null\`.",
            "format": "date-time",
            "type": [
              "string",
              "null",
            ],
          },
          "id": {
            "description": "ID of the quote.",
            "example": "qt_0YV7DES3WPC5J8JD8QTVNZBZNZ",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "interimOnly": {
            "default": true,
            "description": "Specifies if the quotation invoice must include interim items only.
If this value is set to \`false\`, all upcoming items are included.",
            "type": "boolean",
          },
          "invoiceId": {
            "description": "ID of the payment invoice.",
            "example": "in_0YVF9605RKC62BP14NE2R7V2XT",
            "maxLength": 50,
            "readOnly": true,
            "type": "string",
          },
          "invoicePreview": {
            "description": "Preview of the quote invoice.",
            "properties": {
